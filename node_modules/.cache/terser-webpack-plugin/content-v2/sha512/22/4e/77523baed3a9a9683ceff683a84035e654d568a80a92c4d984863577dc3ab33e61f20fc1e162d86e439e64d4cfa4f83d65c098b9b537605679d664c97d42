  { label: 'CloudFront', type: 'aws_cloudfront', alwaysOn: true  },\n          { label: 'EC2',        type: 'aws_ec2',        alwaysOn: true  },\n        ],\n      },\n      {\n        name: 'AWS Billing',\n        gcpProjectId: null,\n        dashboardGuid: 'Nzc4MjQ3OXxWSVp8REFTSEJPQVJEfGRhOjEyMTg1NjI5',\n        dashboardLink: 'https://onenr.io/0Vwg7Wz8ZwJ',\n        billingOnly: true,\n        resources: [\n          { label: 'Total Cost (INR)', type: 'aws_billing', alwaysOn: false },\n        ],\n      },\n    ],\n  },\n];\n\n// ─── NRQL BUILDERS ───────────────────────────────────────────────────────────\nconst buildResourceQuery = (resource, gcpProjectId) => {\n  const gcpFilter = gcpProjectId ? `WHERE projectId = '${gcpProjectId}'` : '';\n\n  switch (resource.type) {\n    case 'gcp_cloudrun':\n      return `SELECT\n                sum(container.BillableInstanceTime) AS billableTime,\n                count(*) AS samples\n              FROM GcpRunRevisionSample\n              ${gcpFilter}\n              SINCE 5 minutes ago`;\n\n    case 'gcp_cloudsql':\n      return `SELECT count(*) AS samples\n              FROM GcpCloudSqlSample\n              ${gcpFilter}\n              SINCE 30 minutes ago`;\n\n    case 'gcp_bigquery':\n      return `SELECT count(*) AS samples\n              FROM GcpBigQueryDataSetSample\n              ${gcpFilter}\n              SINCE 30 minutes ago`;\n\n    case 'gcp_billing':\n      return `SELECT count(*) AS samples FROM Metric SINCE 1 hour ago LIMIT 1`;\n\n    case 'aws_apprunner':\n      return `SELECT\n                max(\\`aws.apprunner.ActiveInstances\\`) AS peakInstances,\n                sum(\\`aws.apprunner.Requests\\`) AS totalRequests,\n                average(\\`aws.apprunner.RequestLatency\\`) AS avgLatency,\n                sum(\\`aws.apprunner.4xxStatusResponses\\`) AS errors4xx,\n                count(*) AS samples\n              FROM Metric\n              WHERE aws.Namespace = 'AWS/AppRunner'\n              SINCE 30 minutes ago`;\n\n    case 'aws_rds':\n      return `SELECT\n                average(\\`aws.rds.FreeableMemory\\`) AS freeMemory,\n                average(\\`aws.rds.WriteIOPS\\`) AS writeIOPS,\n                average(\\`aws.rds.WriteLatency\\`) AS writeLatency,\n                count(*) AS samples\n              FROM Metric\n              WHERE aws.Namespace = 'AWS/RDS'\n              SINCE 1 hour ago`;\n\n    case 'aws_cloudfront':\n      return `SELECT\n                average(\\`aws.cloudfront.5xxErrorRate\\`) AS errorRate5xx,\n                average(\\`aws.cloudfront.TotalErrorRate\\`) AS totalErrorRate,\n                sum(\\`aws.cloudfront.Requests\\`) AS totalRequests\n              FROM Metric\n              WHERE aws.Namespace = 'AWS/CloudFront'\n              SINCE 24 hours ago`;\n\n    case 'aws_ec2':\n      // SINCE 5 minutes: stopped instances emit NO CloudWatch metrics in last 5 min.\n      // samples=0 → nothing running → yellow. samples>0 → at least one instance active.\n      return `SELECT\n                max(\\`aws.ec2.StatusCheckFailed\\`) AS statusCheckFailed,\n                max(\\`aws.ec2.StatusCheckFailed_Instance\\`) AS instanceCheckFailed,\n                average(\\`aws.ec2.CPUUtilization\\`) AS cpuUsage,\n                count(*) AS samples\n              FROM Metric\n              WHERE aws.Namespace = 'AWS/EC2'\n              SINCE 5 minutes ago`;\n\n    case 'aws_billing':\n      return `SELECT\n                max(\\`aws.billing.EstimatedCharges\\`) * 92 AS totalCostINR,\n                count(*) AS samples\n              FROM Metric\n              WHERE aws.Namespace = 'AWS/Billing'\n              SINCE 1 hour ago`;\n\n    default:\n      return `SELECT count(*) AS samples\n              FROM Metric\n              WHERE entity.name = '${resource.label}'\n              SINCE 5 minutes ago`;\n  }\n};\n\n// ─── HEALTH DERIVATION ───────────────────────────────────────────────────────\nconst noData = (resource) => {\n  if (resource.scalesToZero) return 'green';\n  return resource.alwaysOn ? 'yellow' : 'unknown';\n};\n\nconst deriveResourceStatus = (resource, row) => {\n  if (!row) return noData(resource);\n\n  switch (resource.type) {\n    case 'gcp_cloudrun': {\n      const samples = row.samples ?? 0;\n      if (samples === 0) return noData(resource);\n      return 'green';\n    }\n    case 'gcp_cloudsql': {\n      const samples = row.samples ?? 0;\n      if (samples === 0) return noData(resource);\n      return 'green';\n    }\n    case 'gcp_bigquery': {\n      const samples = row.samples ?? 0;\n      if (samples === 0) return 'unknown';\n      return 'green';\n    }\n    case 'gcp_billing': {\n      return 'unknown';\n    }\n    case 'aws_apprunner': {\n      const samples = row.samples ?? 0;\n      if (samples === 0) return noData(resource);\n      const peak = row.peakInstances ?? null;\n      if (peak === null || peak === 0) return 'yellow';\n      return 'green';\n    }\n    case 'aws_rds': {\n      const samples  = row.samples ?? 0;\n      if (samples === 0) return noData(resource);\n      const freeMem  = row.freeMemory   ?? null;\n      const writeLat = row.writeLatency ?? null;\n      if (freeMem !== null && freeMem < 50 * 1024 * 1024)  return 'red';\n      if (freeMem !== null && freeMem < 200 * 1024 * 1024) return 'yellow';\n      if (writeLat !== null && writeLat > 1)                return 'yellow';\n      return 'green';\n    }\n    case 'aws_cloudfront': {\n      const requests = row.totalRequests ?? null;\n      const err5xx   = row.errorRate5xx  ?? null;\n      const errAll   = row.totalErrorRate ?? null;\n      if (requests === null && err5xx === null && errAll === null) return noData(resource);\n      const rate = err5xx ?? errAll ?? null;\n      if (rate !== null && rate > 5) return 'red';\n      if (rate !== null && rate > 2) return 'yellow';\n      return 'green';\n    }\n    case 'aws_ec2': {\n      // SINCE 5 min window: CloudWatch only emits metrics for RUNNING instances.\n      // samples=0 in last 5 min means no instance is actively running → yellow (alwaysOn).\n      const samples      = row.samples ?? 0;\n      if (samples === 0) return 'yellow';\n      const statusFailed = typeof row.statusCheckFailed   === 'number' ? row.statusCheckFailed : 0;\n      const instanceFail = typeof row.instanceCheckFailed === 'number' ? row.instanceCheckFailed : 0;\n      const cpu          = typeof row.cpuUsage            === 'number' ? row.cpuUsage : null;\n      if (statusFailed > 0 || instanceFail > 0) return 'red';\n      if (cpu !== null && cpu > 90) return 'red';\n      if (cpu !== null && cpu > 75) return 'yellow';\n      return 'green';\n    }\n    case 'aws_billing': {\n      const samples = row.samples ?? 0;\n      if (samples === 0) return 'unknown';\n      return 'green';\n    }\n    default: {\n      const samples = row.samples ?? 0;\n      return samples === 0 ? noData(resource) : 'green';\n    }\n  }\n};\n\n// ─── STATUS UTILS ────────────────────────────────────────────────────────────\nconst worstStatus = (statuses) => {\n  if (statuses.some((s) => s === 'red'))    return 'red';\n  if (statuses.some((s) => s === 'yellow')) return 'yellow';\n  if (statuses.some((s) => s === 'green'))  return 'green';\n  return 'unknown';\n};\n\nconst STATUS_META = {\n  green:   { label: 'Healthy',      color: '#00d4aa' },\n  yellow:  { label: 'Warning',      color: '#f5a623' },\n  red:     { label: 'Critical',     color: '#ff4d6d' },\n  unknown: { label: 'No Data',      color: '#7a8aaa' },\n  deleted: { label: 'Deleted',      color: '#4a5568' },\n  empty:   { label: 'No Resources', color: '#3d4a66' },\n};\n\nconst PROVIDER_META = {\n  gcp: {\n    gradient: 'linear-gradient(135deg, rgba(66,133,244,0.18) 0%, rgba(52,168,83,0.10) 100%)',\n    accent: '#4285F4',\n  },\n  aws: {\n    gradient: 'linear-gradient(135deg, rgba(255,153,0,0.18) 0%, rgba(255,90,0,0.10) 100%)',\n    accent: '#FF9900',\n  },\n};\n\n// ─── RESOURCE TYPE HELPERS ───────────────────────────────────────────────────\nconst canBePaused = (resourceType) => resourceType === 'aws_apprunner';\n\n// ─── EC2 INSTANCE STATE HELPER ───────────────────────────────────────────────\nconst ec2StateDisplay = (state) => {\n  const s = (state ?? '').toString().toLowerCase().trim();\n  switch (s) {\n    case 'running':       return { dot: 'green',  label: '✓ Running',      color: '#00d4aa' };\n    case 'impaired':      return { dot: 'red',    label: '✗ Impaired',     color: '#ff4d6d' };\n    // FIX: changed ⊘ to ✗ for stopped state\n    case 'stopped':       return { dot: 'yellow', label: '✗ Stopped',      color: '#f5a623' };\n    case 'terminated':    return { dot: 'grey',   label: '✗ Terminated',   color: '#4a5568' };\n    case 'pending':       return { dot: 'yellow', label: '◌ Pending',       color: '#f5a623' };\n    case 'stopping':      return { dot: 'yellow', label: '◌ Stopping',      color: '#f5a623' };\n    case 'shutting-down': return { dot: 'yellow', label: '◌ Shutting Down', color: '#f5a623' };\n    default:              return { dot: 'grey',   label: s || '— Unknown',  color: '#7a8aaa' };\n  }\n};\n\n// ─── BILLING HEALTH BADGE ────────────────────────────────────────────────────\nconst BILLING_BUDGET_INR = 4600;\n\nconst billingCostToStatus = (cost) => {\n  if (cost === null) return 'unknown';\n  const pct = (cost / BILLING_BUDGET_INR) * 100;\n  return pct >= 70 ? 'red' : pct >= 50 ? 'yellow' : 'green';\n};\n\nconst BillingHealthBadge = ({ cost }) => {\n  if (cost === null) {\n    return (\n      <span className=\"status-badge status-badge--grey\">\n        <span className=\"status-badge__dot\" />\n        Billing\n      </span>\n    );\n  }\n  const pct    = (cost / BILLING_BUDGET_INR) * 100;\n  const status = billingCostToStatus(cost);\n  return (\n    <span className={'status-badge status-badge--' + status + ' status-badge--billing'} title={pct.toFixed(1) + '% of monthly budget'}>\n      <span className=\"status-badge__dot\" />\n      <span className=\"status-badge__billing-current\">{'₹' + cost.toFixed(0)}</span>\n      <span className=\"status-badge__billing-sep\">/</span>\n      <span className=\"status-badge__billing-budget\">{'₹' + BILLING_BUDGET_INR + ' budget'}</span>\n    </span>\n  );\n};\n\n// ─── STATUS DOT ──────────────────────────────────────────────────────────────\nconst StatusDot = ({ status }) => {\n  const cls = (status === 'unknown' || status === 'deleted' || status === 'empty') ? 'grey' : status;\n  return <span className={`status-dot status-dot--${cls}`} />;\n};\n\n// ─── STATUS BADGE ─────────────────────────────────────────────────────────────\nconst StatusBadge = ({ status, label }) => {\n  const meta = STATUS_META[status] ?? STATUS_META.green;\n  const cls  = (status === 'unknown' || status === 'deleted' || status === 'empty') ? 'grey' : status;\n  return (\n    <span className={`status-badge status-badge--${cls}`}>\n      <span className=\"status-badge__dot\" />\n      {label ? label : meta.label}\n    </span>\n  );\n};\n\n// ─── RESOURCE METRICS DISPLAY ────────────────────────────────────────────────\nconst ResourceMetrics = ({ resource, row }) => {\n  if (!row) return null;\n  switch (resource.type) {\n    case 'gcp_cloudrun': {\n      const billable = row.billableTime != null ? `${row.billableTime.toFixed(1)}s` : '0.0s';\n      const active   = row.billableTime != null && row.billableTime > 0;\n      return (\n        <span className=\"resource-metrics\">\n          <strong style={{ color: '#00d4aa' }}>{active ? '✓ Running' : '✓ Scaled to zero'}</strong> · Billable: <strong>{billable}</strong>\n        </span>\n      );\n    }\n    case 'gcp_cloudsql': {\n      const samples = row.samples ?? 0;\n      return (\n        <span className=\"resource-metrics\">\n          DB: <strong style={{ color: samples > 0 ? '#00d4aa' : '#f5a623' }}>{samples > 0 ? '✓ Running' : '✗ Stopped'}</strong>\n        </span>\n      );\n    }\n    case 'aws_apprunner': {\n      const instances = row.peakInstances != null ? row.peakInstances.toFixed(0) : '0';\n      const requests  = row.totalRequests != null ? row.totalRequests.toFixed(0) : '0';\n      const latency   = row.avgLatency    != null ? `${row.avgLatency.toFixed(0)} ms` : 'N/A';\n      const errors4xx = row.errors4xx     != null ? row.errors4xx.toFixed(0) : '0';\n      return (\n        <span className=\"resource-metrics\">\n          Peak instances: <strong>{instances}</strong> · Requests: <strong>{requests}</strong> · Latency: <strong>{latency}</strong> · 4xx: <strong>{errors4xx}</strong>\n        </span>\n      );\n    }\n    case 'aws_rds': {\n      const freeMem  = row.freeMemory   != null ? `${(row.freeMemory / (1024 * 1024)).toFixed(0)} MB free` : 'N/A';\n      const writeLat = row.writeLatency != null ? `${(row.writeLatency * 1000).toFixed(1)} ms` : 'N/A';\n      return (\n        <span className=\"resource-metrics\">\n          Mem: <strong>{freeMem}</strong> · Write latency: <strong>{writeLat}</strong>\n        </span>\n      );\n    }\n    case 'aws_ec2': {\n      const cpu    = row.cpuUsage          != null ? `${row.cpuUsage.toFixed(1)}%` : 'N/A';\n      const status = row.statusCheckFailed != null ? (row.statusCheckFailed > 0 ? '✗ Failed' : '✓ OK') : 'N/A';\n      const color  = row.statusCheckFailed > 0 ? '#ff4d6d' : '#00d4aa';\n      return (\n        <span className=\"resource-metrics\">\n          CPU: <strong>{cpu}</strong> · Status check: <strong style={{ color }}>{status}</strong>\n        </span>\n      );\n    }\n    case 'aws_cloudfront': {\n      const err5xx = row.errorRate5xx   != null ? `${row.errorRate5xx.toFixed(2)}%`   : 'N/A';\n      const errAll = row.totalErrorRate != null ? `${row.totalErrorRate.toFixed(2)}%` : 'N/A';\n      const reqs   = row.totalRequests  != null ? ` · Requests: ${row.totalRequests.toFixed(0)}` : '';\n      return (\n        <span className=\"resource-metrics\">\n          5xx: <strong>{err5xx}</strong> · Total err: <strong>{errAll}</strong>{reqs}\n        </span>\n      );\n    }\n    case 'aws_billing': {\n      const cost = row.totalCostINR != null ? `₹${row.totalCostINR.toFixed(2)}` : 'N/A';\n      return (\n        <span className=\"resource-metrics\">\n          Est. Cost (today): <strong>{cost}</strong>\n        </span>\n      );\n    }\n    default:\n      return null;\n  }\n};\n\n// ─── CLOUD RUN INSTANCE LIST ─────────────────────────────────────────────────\nconst CloudRunInstanceList = ({ gcpProjectId }) => {\n  if (!gcpProjectId) return null;\n  const query = `SELECT sum(container.BillableInstanceTime) AS billableTime\n                 FROM GcpRunRevisionSample\n                 WHERE projectId = '${gcpProjectId}'\n                 FACET serviceName\n                 SINCE 30 minutes ago\n                 LIMIT 50`;\n  return (\n    <NrqlQuery accountIds={[ACCOUNT_ID]} query={query} pollInterval={60000}>\n      {({ data, loading, error }) => {\n        if (loading) return (\n          <div className=\"cr-instances cr-instances--loading\">\n            <span style={{ fontSize: '11px', color: '#7a8aaa', fontStyle: 'italic' }}>Loading instances…</span>\n          </div>\n        );\n        if (error || !data || data.length === 0) return null;\n        const instances = data.map((series) => {\n          let serviceName = series?.metadata?.name ?? null;\n          if (!serviceName || serviceName === 'Other') {\n            const groups = series?.metadata?.groups ?? [];\n            const g = groups.find(g => g.type === 'facet' || g.name === 'serviceName');\n            serviceName = g?.value ?? null;\n          }\n          if (!serviceName) {\n            const facets = series?.metadata?.facets ?? [];\n            serviceName = facets[0] ?? null;\n          }\n          if (!serviceName) return null;\n          const billable = series?.data?.[0]?.y ?? 0;\n          return { serviceName, billable, active: billable > 0 };\n        }).filter(Boolean);\n        if (instances.length === 0) return null;\n        instances.sort((a, b) => {\n          if (a.active !== b.active) return b.active ? 1 : -1;\n          return a.serviceName.localeCompare(b.serviceName);\n        });\n        return (\n          <div className=\"cr-instances\">\n            <div className=\"cr-instances__header\">☁ Cloud Run Services ({instances.length})</div>\n            {instances.map((inst, i) => (\n              <div key={i} className=\"cr-instances__row\">\n                <span className=\"status-dot status-dot--green\" style={{ width: 7, height: 7 }} />\n                <span className=\"cr-instances__name\">{inst.serviceName}</span>\n                <span className=\"cr-instances__status\" style={{ color: '#00d4aa' }}>\n                  {inst.active ? '▶ Running' : '◼ Scaled to zero'}\n                </span>\n                {inst.active && <span className=\"cr-instances__billable\">{inst.billable.toFixed(1)}s billable</span>}\n              </div>\n            ))}\n          </div>\n        );\n      }}\n    </NrqlQuery>\n  );\n};\n\n// ─── SERVICE QUERIES ─────────────────────────────────────────────────────────\nconst SERVICE_QUERIES = {\n  gcp_cloudrun:   (p) => `SELECT count(*) AS val FROM GcpRunRevisionSample WHERE projectId = '${p.gcpProjectId}' FACET serviceName SINCE 30 days ago LIMIT 100`,\n  gcp_cloudsql:   (p) => `SELECT count(*) AS val FROM GcpCloudSqlSample WHERE projectId = '${p.gcpProjectId}' FACET displayName SINCE 30 minutes ago LIMIT 20`,\n  gcp_bigquery:   (p) => `SELECT count(*) AS val FROM GcpBigQueryDataSetSample WHERE projectId = '${p.gcpProjectId}' FACET datasetId SINCE 30 minutes ago LIMIT 20`,\n  aws_apprunner:  ()  => \"SELECT count(*) AS val FROM Metric WHERE aws.Namespace = 'AWS/AppRunner' FACET aws.apprunner.ServiceName SINCE 30 minutes ago LIMIT 30\",\n  aws_rds:        ()  => \"SELECT latest(provider.dbInstanceIdentifier) AS val FROM DatastoreSample WHERE provider = 'RdsDbInstance' FACET provider.dbInstanceIdentifier SINCE 7 days ago LIMIT 20\",\n  // CloudWatch EC2: use StatusCheckFailed + CPUUtilization to infer health per instance\n  aws_ec2: () => \"SELECT latest(`aws.ec2.StatusCheckFailed`) AS statusFailed, latest(`aws.ec2.CPUUtilization`) AS cpu FROM Metric WHERE aws.Namespace = 'AWS/EC2' FACET `aws.ec2.InstanceId` SINCE 30 days ago LIMIT 50\",\n  aws_cloudfront: () => \"SELECT count(*) AS val FROM Metric WHERE aws.Namespace = 'AWS/CloudFront' FACET aws.cloudfront.DistributionId SINCE 24 hours ago LIMIT 20\",\n};\n\n// ─── FACET EXTRACTION HELPERS ────────────────────────────────────────────────\nconst extractFacetName = (series) => {\n  const groups = series?.metadata?.groups;\n  if (Array.isArray(groups)) {\n    const g = groups.find(g => g.type === 'facet');\n    if (g?.value && g.value !== 'Other') return g.value;\n  }\n  const pt = series?.data?.[0];\n  if (pt?.facet) return Array.isArray(pt.facet) ? pt.facet[0] : String(pt.facet);\n  const name = series?.metadata?.name;\n  const SKIP = new Set(['val', 'Other', 'unknown', 'count', 'latest', 'FreeableMemory',\n    'WriteIOPS', 'WriteLatency', 'ReadIOPS', 'CPUUtilization']);\n  if (name && !SKIP.has(name)) return name;\n  return null;\n};\n\n// ─── EC2 FACET EXTRACTION (CloudWatch-based) ────────────────────────────────\nconst extractEc2FacetPair = (series) => {\n  let name = null;\n  const groups = series?.metadata?.groups;\n  if (Array.isArray(groups)) {\n    const facets = groups.filter(g => g.type === 'facet');\n    if (facets.length >= 1) name = facets[0].value;\n  }\n  if (!name) {\n    const pt = series?.data?.[0];\n    if (pt?.facet) name = Array.isArray(pt.facet) ? pt.facet[0] : String(pt.facet);\n  }\n  if (!name) {\n    const n = series?.metadata?.name;\n    const SKIP = new Set(['val', 'Other', 'unknown', 'count', 'statusFailed', 'cpu']);\n    if (n && !SKIP.has(n)) name = n;\n  }\n  if (!name) return null;\n\n  const pt = series?.data?.[0];\n  const statusFailed = pt?.statusFailed ?? null;\n  const state = (statusFailed === null || statusFailed === undefined)\n    ? 'stopped'\n    : statusFailed > 0 ? 'impaired' : 'running';\n\n  return { name, state };\n};\n\n// ─── EXPANDABLE RESOURCE ROW ─────────────────────────────────────────────────\nconst ExpandableResourceRow = ({ resource: r, project }) => {\n  const [open, setOpen] = React.useState(false);\n  const hasSubList = !!SERVICE_QUERIES[r.type];\n\n  const dotCls      = r.status === 'green' ? 'green' : r.status === 'yellow' ? 'yellow' : r.status === 'red' ? 'red' : 'grey';\n  const statusColor = r.status === 'green' ? '#00d4aa' : r.status === 'yellow' ? '#f5a623' : r.status === 'red' ? '#ff4d6d' : '#7a8aaa';\n  const statusLabel = r.status === 'green'  ? '✓ Running'\n                    : r.status === 'yellow' ? (canBePaused(r.type) ? '⊘ Paused' : '✗ Stopped')\n                    : r.status === 'red'    ? '✗ Stopped'\n                    : '— No Data';\n\n  const query = hasSubList ? SERVICE_QUERIES[r.type](project) : null;\n\n  return (\n    <div style={{ borderRadius: 6, overflow: 'hidden', background: 'rgba(255,255,255,0.03)' }}>\n      <div\n        style={{ display: 'flex', alignItems: 'center', gap: 8, padding: '5px 8px', cursor: hasSubList ? 'pointer' : 'default' }}\n        onClick={() => hasSubList && setOpen(o => !o)}\n      >\n        <span className={'status-dot status-dot--' + dotCls} />\n        <span style={{ fontWeight: 600, fontSize: '0.8rem', minWidth: 80, color: '#f0f4ff', flex: 1 }}>{r.label}</span>\n        <span style={{ color: statusColor, fontSize: '0.75rem', fontWeight: 600 }}>{statusLabel}</span>\n        {hasSubList && (\n          <span style={{ fontSize: 14, color: '#3d4a66', transition: 'transform 0.2s', display: 'inline-block', transform: open ? 'rotate(90deg)' : 'rotate(0deg)' }}>›</span>\n        )}\n      </div>\n\n      {open && query && (\n        <NrqlQuery accountIds={[ACCOUNT_ID]} query={query} pollInterval={60000}>\n          {({ data, loading }) => {\n            if (loading) return <div style={{ padding: '4px 12px 6px', fontSize: 11, color: '#7a8aaa', fontStyle: 'italic' }}>Loading…</div>;\n            if (!data || data.length === 0) return <div style={{ padding: '4px 12px 6px', fontSize: 11, color: '#7a8aaa' }}>No instances found</div>;\n\n            const accentColor = r.type.startsWith('aws') ? 'rgba(255,153,0,0.08)' : 'rgba(66,133,244,0.08)';\n            const borderColor = r.type.startsWith('aws') ? 'rgba(255,153,0,0.12)' : 'rgba(66,133,244,0.12)';\n\n            // ── Cloud Run: dual-query to show all services incl. scaled-to-zero ──\n            // data = 30-day GcpRunRevisionSample (all revisions ever seen per service)\n            // active query = 5-min billableTime > 0 → currently running\n            // Services absent from active = scaled to zero (healthy, not missing)\n            if (r.type === 'gcp_cloudrun') {\n              const activeQuery = `SELECT sum(container.BillableInstanceTime) AS billableTime FROM GcpRunRevisionSample WHERE projectId = '${project.gcpProjectId}' FACET serviceName SINCE 30 minutes ago LIMIT 100`;\n              return (\n                <NrqlQuery accountIds={[ACCOUNT_ID]} query={activeQuery} pollInterval={60000}>\n                  {({ data: activeData, loading: activeLoading }) => {\n                    if (activeLoading) return <div style={{ padding: '4px 12px 6px', fontSize: 11, color: '#7a8aaa', fontStyle: 'italic' }}>Loading…</div>;\n\n                    // Services with billable time in last 30 min = actively running\n                    const activeServices = new Set();\n                    (activeData || []).forEach(series => {\n                      let name = null;\n                      const groups = series?.metadata?.groups;\n                      if (Array.isArray(groups)) {\n                        const g = groups.find(g => g.type === 'facet');\n                        if (g?.value) name = g.value;\n                      }\n                      if (!name) {\n                        const pt = series?.data?.[0];\n                        if (pt?.facet) name = Array.isArray(pt.facet) ? pt.facet[0] : String(pt.facet);\n                      }\n                      if (!name) name = series?.metadata?.name;\n                      const billable = series?.data?.[0]?.y ?? 0;\n                      if (name && billable > 0) activeServices.add(name);\n                    });\n\n                    // All known services from 30-day GcpRunRevisionSample\n                    const seen = new Set();\n                    const NONSVC = new Set(['val', 'Other', 'unknown', 'count', 'latest']);\n                    const allServices = data.map(series => {\n                      // Try groups facet first\n                      let name = null;\n                      const groups = series?.metadata?.groups;\n                      if (Array.isArray(groups)) {\n                        const g = groups.find(g => g.type === 'facet');\n                        if (g?.value) name = g.value;\n                      }\n                      // Try data point facet\n                      if (!name) {\n                        const pt = series?.data?.[0];\n                        if (pt?.facet) name = Array.isArray(pt.facet) ? pt.facet[0] : String(pt.facet);\n                      }\n                      // Try metadata name (no SKIP filter for Cloud Run service names)\n                      if (!name) name = series?.metadata?.name;\n                      if (!name || NONSVC.has(name) || seen.has(name)) return null;\n                      seen.add(name);\n                      return name;\n                    }).filter(Boolean);\n\n                    if (allServices.length === 0) return <div style={{ padding: '4px 12px 6px', fontSize: 11, color: '#7a8aaa' }}>No services found</div>;\n\n                    // Sort: running first, then scaled-to-zero, both alphabetical\n                    allServices.sort((a, b) => {\n                      const aActive = activeServices.has(a);\n                      const bActive = activeServices.has(b);\n                      if (aActive !== bActive) return bActive ? 1 : -1;\n                      return a.localeCompare(b);\n                    });\n\n                    return (\n                      <div style={{ margin: '0 8px 6px', background: accentColor, border: '1px solid ' + borderColor, borderRadius: 6, overflow: 'hidden' }}>\n                        {allServices.map((name, i) => {\n                          const isRunning = activeServices.has(name);\n                          return (\n                            <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 8, padding: '5px 10px', borderBottom: i < allServices.length - 1 ? '1px solid rgba(255,255,255,0.04)' : 'none' }}>\n                              <span className=\"status-dot status-dot--green\" style={{ width: 6, height: 6, flexShrink: 0 }} />\n                              <span style={{ fontSize: 11, color: '#c8d4f0', fontFamily: 'monospace', flex: 1, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{name}</span>\n                              <span style={{ fontSize: 10, color: '#00d4aa', fontWeight: 600, whiteSpace: 'nowrap' }}>{isRunning ? '▶ Running' : '◼ Scaled to zero'}</span>\n                            </div>\n                          );\n                        })}\n                      </div>\n                    );\n                  }}\n                </NrqlQuery>\n              );\n            }\n\n            // ── EC2: dual-query approach ──────────────────────────────────────\n            // data = 30-day query (all known instances)\n            // We cross-reference with a 10-min query to determine which are currently running.\n            // CloudWatch only emits metrics for RUNNING instances, so absence in 10-min = stopped.\n            if (r.type === 'aws_ec2') {\n              const activeQuery = \"SELECT latest(`aws.ec2.StatusCheckFailed`) AS statusFailed FROM Metric WHERE aws.Namespace = 'AWS/EC2' FACET `aws.ec2.InstanceId` SINCE 10 minutes ago LIMIT 50\";\n              return (\n                <NrqlQuery accountIds={[ACCOUNT_ID]} query={activeQuery} pollInterval={60000}>\n                  {({ data: activeData, loading: activeLoading }) => {\n                    if (activeLoading) return <div style={{ padding: '4px 12px 6px', fontSize: 11, color: '#7a8aaa', fontStyle: 'italic' }}>Loading…</div>;\n\n                    // Build set of currently-active instance IDs (seen in last 10 min)\n                    const activeInstances = new Set();\n                    const impairedInstances = new Set();\n                    (activeData || []).forEach(series => {\n                      const pair = extractEc2FacetPair(series);\n                      if (!pair?.name) return;\n                      activeInstances.add(pair.name);\n                      if (pair.state === 'impaired') impairedInstances.add(pair.name);\n                    });\n\n                    // All known instances from 30-day query\n                    const seen = new Set();\n                    const allKnown = data.map(series => {\n                      const pair = extractEc2FacetPair(series);\n                      if (!pair?.name || seen.has(pair.name)) return null;\n                      seen.add(pair.name);\n                      return pair.name;\n                    }).filter(Boolean);\n\n                    if (allKnown.length === 0) return <div style={{ padding: '4px 12px 6px', fontSize: 11, color: '#7a8aaa' }}>No instances found</div>;\n\n                    // Derive accurate state per instance\n                    const instances = allKnown.map(name => {\n                      const state = impairedInstances.has(name) ? 'impaired'\n                                  : activeInstances.has(name)   ? 'running'\n                                  : 'stopped';\n                      return { name, state };\n                    });\n\n                    // Sort: running → stopped → impaired → terminated\n                    const stateOrder = { running: 0, pending: 1, stopping: 2, stopped: 3, 'shutting-down': 4, terminated: 5, impaired: 6 };\n                    instances.sort((a, b) => {\n                      const ao = stateOrder[a.state] ?? 99;\n                      const bo = stateOrder[b.state] ?? 99;\n                      return ao !== bo ? ao - bo : a.name.localeCompare(b.name);\n                    });\n\n                    // If ALL are stopped, ensure parent EC2 row shows yellow\n                    const allStopped = instances.every(inst => inst.state === 'stopped' || inst.state === 'terminated');\n                    if (allStopped) r.status = 'yellow';\n\n                    return (\n                      <div style={{ margin: '0 8px 6px', background: accentColor, border: '1px solid ' + borderColor, borderRadius: 6, overflow: 'hidden' }}>\n                        {instances.map((inst, i) => {\n                          const display = ec2StateDisplay(inst.state);\n                          return (\n                            <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 8, padding: '5px 10px', borderBottom: i < instances.length - 1 ? '1px solid rgba(255,255,255,0.04)' : 'none' }}>\n                              <span className={'status-dot status-dot--' + display.dot} style={{ width: 6, height: 6, flexShrink: 0 }} />\n                              <span style={{ fontSize: 11, color: '#c8d4f0', fontFamily: 'monospace', flex: 1, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{inst.name}</span>\n                              <span style={{ fontSize: 10, color: display.color, fontWeight: 600, whiteSpace: 'nowrap' }}>{display.label}</span>\n                            </div>\n                          );\n                        })}\n                      </div>\n                    );\n                  }}\n                </NrqlQuery>\n              );\n            }\n\n            // ── All other resource types ──────────────────────────────────────\n            const seen = new Set();\n            const items = data.map(series => {\n              const name = extractFacetName(series);\n              if (!name || seen.has(name)) return null;\n              seen.add(name);\n              return name;\n            }).filter(Boolean);\n\n            if (items.length === 0) return <div style={{ padding: '4px 12px 6px', fontSize: 11, color: '#7a8aaa' }}>No instances found</div>;\n\n            const instDot   = r.status === 'green' ? 'green' : 'yellow';\n            const instLabel = r.status === 'green' ? '✓ Running' : canBePaused(r.type) ? '⊘ Paused' : '✗ Stopped';\n            const instColor = r.status === 'green' ? '#00d4aa' : '#f5a623';\n\n            return (\n              <div style={{ margin: '0 8px 6px', background: accentColor, border: '1px solid ' + borderColor, borderRadius: 6, overflow: 'hidden' }}>\n                {items.map((name, i) => (\n                  <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 8, padding: '4px 10px', borderBottom: i < items.length - 1 ? '1px solid rgba(255,255,255,0.04)' : 'none' }}>\n                    <span className={'status-dot status-dot--' + instDot} style={{ width: 6, height: 6, flexShrink: 0 }} />\n                    <span style={{ fontSize: 11, color: '#c8d4f0', fontFamily: 'monospace', flex: 1, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{name}</span>\n                    <span style={{ fontSize: 10, color: instColor, fontWeight: 600 }}>{instLabel}</span>\n                  </div>\n                ))}\n              </div>\n            );\n          }}\n        </NrqlQuery>\n      )}\n    </div>\n  );\n};\n\n// ─── BILLING SIMPLE ───────────────────────────────────────────────────────────\nconst BillingSimple = ({ cost, budget }) => {\n  if (cost === null) return (\n    <div style={{ color: '#7a8aaa', fontSize: 12, fontStyle: 'italic' }}>No billing data</div>\n  );\n  const now         = new Date();\n  const dayOfMonth  = now.getDate();\n  const daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();\n  const estimated   = (cost / dayOfMonth) * daysInMonth;\n  const status      = billingCostToStatus(cost);\n  const estStatus   = billingCostToStatus(estimated);\n  const color       = status    === 'red' ? '#ff4d6d' : status    === 'yellow' ? '#f5a623' : '#00d4aa';\n  const estColor    = estStatus === 'red' ? '#ff4d6d' : estStatus === 'yellow' ? '#f5a623' : '#00d4aa';\n  const pct         = Math.min((cost / budget) * 100, 100);\n  const fullPct     = ((cost / budget) * 100).toFixed(1);\n  const statStyle   = { flex: 1, padding: '8px 10px', background: 'rgba(255,255,255,0.03)', borderRadius: 8, border: '1px solid rgba(255,255,255,0.07)' };\n  const labelStyle  = { fontSize: 10, color: '#7a8aaa', textTransform: 'uppercase', letterSpacing: 1, marginBottom: 4 };\n  const valStyle    = (c) => ({ fontSize: 18, fontWeight: 800, color: c });\n  return (\n    <div style={{ padding: '6px 4px' }}>\n      <div style={{ display: 'flex', gap: 8, marginBottom: 10 }}>\n        <div style={statStyle}><div style={labelStyle}>Current</div><div style={valStyle(color)}>{'₹' + cost.toFixed(0)}</div></div>\n        <div style={statStyle}><div style={labelStyle}>Est. Month-end</div><div style={valStyle(estColor)}>{'₹' + estimated.toFixed(0)}</div></div>\n        <div style={statStyle}><div style={labelStyle}>Budget</div><div style={valStyle('#f0f4ff')}>{'₹' + budget}</div></div>\n      </div>\n      <div style={{ background: 'rgba(255,255,255,0.06)', borderRadius: 4, height: 6, overflow: 'hidden' }}>\n        <div style={{ height: '100%', width: pct + '%', background: color, borderRadius: 4, transition: 'width 0.4s' }} />\n      </div>\n      <div style={{ marginTop: 4, fontSize: 10, color: color, textAlign: 'right', fontWeight: 600 }}>\n        {fullPct + '% of budget used · Day ' + dayOfMonth + ' of ' + daysInMonth}\n      </div>\n    </div>\n  );\n};\n\n// ─── GCP BILLING NOT CONFIGURED PANEL ────────────────────────────────────────\nconst GcpBillingNotConfigured = () => (\n  <div style={{ display: 'flex', alignItems: 'flex-start', gap: 10, padding: '10px 12px',\n    background: 'rgba(66,133,244,0.06)', border: '1px dashed rgba(66,133,244,0.25)', borderRadius: 8, margin: '4px 0' }}>\n    <span style={{ fontSize: 16, lineHeight: 1.2, opacity: 0.6 }}>🔧</span>\n    <div>\n      <div style={{ fontSize: 12, fontWeight: 700, color: '#4285f4', marginBottom: 2 }}>Not Configured</div>\n      <div style={{ fontSize: 11, color: '#7a8aaa', lineHeight: 1.5 }}>\n        GCP Billing export to BigQuery has not been set up yet.\n        Configure it in the GCP Console to enable cost monitoring here.\n      </div>\n    </div>\n  </div>\n);\n\n// ─── DOWN SERVICES PANEL ──────────────────────────────────────────────────────\nconst DownServicesPanel = ({ downResources }) => {\n  if (!downResources || downResources.length === 0) return null;\n  return (\n    <div className=\"down-services\">\n      <div className=\"down-services__header\">\n        <span className=\"down-services__icon\">⚠</span>\n        <span className=\"down-services__title\">Services Requiring Attention</span>\n      </div>\n      <ul className=\"down-services__list\">\n        {downResources.map((r, i) => {\n          const badgeCls   = r.status === 'unknown' ? 'grey' : r.status;\n          const isStopped  = !r.row || (r.row.samples ?? 0) === 0;\n          const badgeLabel = r.status === 'unknown' ? 'No Data'\n                           : r.status === 'red'     ? (isStopped ? 'Stopped' : 'Critical')\n                           : r.status === 'yellow'  ? (canBePaused(r.type) ? 'Paused' : 'Stopped')\n                           : 'OK';\n          return (\n            <li key={i} className={`down-services__item down-services__item--${badgeCls}`}>\n              <span className=\"down-services__item-dot\" />\n              <span className=\"down-services__item-name\">{r.label}</span>\n              <span className={`down-services__item-badge down-services__item-badge--${badgeCls}`}>{badgeLabel}</span>\n            </li>\n          );\n        })}\n      </ul>\n    </div>\n  );\n};\n\n// ─── BILLING BREAKDOWN ───────────────────────────────────────────────────────\nconst BillingBreakdown = () => {\n  const totalQuery      = `SELECT max(\\`aws.billing.EstimatedCharges\\`) * 92 AS totalINR FROM Metric WHERE aws.Namespace = 'AWS/Billing' AND aws.ServiceName IS NULL SINCE 1 day ago`;\n  const byServiceQuery  = `SELECT max(\\`aws.billing.EstimatedCharges\\`) * 92 AS costINR FROM Metric WHERE aws.Namespace = 'AWS/Billing' AND aws.ServiceName IS NOT NULL FACET aws.ServiceName SINCE 1 day ago LIMIT 20`;\n  return (\n    <NrqlQuery accountIds={[ACCOUNT_ID]} query={byServiceQuery} pollInterval={300000}>\n      {({ data: svcData, loading: svcLoading }) => (\n        <NrqlQuery accountIds={[ACCOUNT_ID]} query={totalQuery} pollInterval={300000}>\n          {({ data: totData, loading: totLoading }) => {\n            if (svcLoading || totLoading) return <div style={{ color: '#7a8aaa', fontSize: 12, padding: '8px 0', fontStyle: 'italic' }}>Loading billing data…</div>;\n            const totalINR = totData?.[0]?.data?.[0]?.y ?? totData?.[0]?.data?.[0]?.totalINR ?? null;\n            const services = (svcData || [])\n              .map(series => ({ name: series?.metadata?.name || '—', cost: series?.data?.[0]?.y ?? 0 }))\n              .filter(s => s.name !== '—' && s.cost > 0)\n              .sort((a, b) => b.cost - a.cost);\n            return (\n              <div className=\"billing-breakdown\">\n                {totalINR != null && (\n                  <div className=\"billing-breakdown__total\">\n                    <span className=\"billing-breakdown__total-label\">Total this month</span>\n                    <span className=\"billing-breakdown__total-value\">₹{totalINR.toFixed(2)}</span>\n                  </div>\n                )}\n                {services.length > 0 ? (\n                  <div className=\"billing-breakdown__services\">\n                    {services.map((s, i) => {\n                      const pct = totalINR ? (s.cost / totalINR) * 100 : 0;\n                      return (\n                        <div key={i} className=\"billing-breakdown__row\">\n                          <span className=\"billing-breakdown__svc-name\">{s.name}</span>\n                          <div className=\"billing-breakdown__bar-wrap\"><div className=\"billing-breakdown__bar\" style={{ width: `${Math.min(pct, 100)}%` }} /></div>\n                          <span className=\"billing-breakdown__svc-cost\">₹{s.cost.toFixed(0)}</span>\n                          <span className=\"billing-breakdown__svc-pct\">{pct.toFixed(1)}%</span>\n                        </div>\n                      );\n                    })}\n                  </div>\n                ) : (\n                  <div style={{ color: '#7a8aaa', fontSize: 12, padding: '4px 0' }}>No per-service data available</div>\n                )}\n              </div>\n            );\n          }}\n        </NrqlQuery>\n      )}\n    </NrqlQuery>\n  );\n};\n\n// ─── PROJECT ROW ─────────────────────────────────────────────────────────────\nconst ProjectRow = ({ project, resourceStatuses, loading, index, billingCost }) => {\n  const [expanded, setExpanded] = useState(false);\n\n  if (project.deleted) {\n    return (\n      <div className=\"project-row project-row--deleted\" style={{ animationDelay: index * 80 + 'ms' }}>\n        <div className=\"project-row__main\">\n          <div className=\"project-row__left\" style={{ gap: 10 }}>\n            <span style={{ fontSize: 14, opacity: 0.65 }}>🗑</span>\n            <span className=\"project-row__name\" style={{ color: '#8899bb' }}>{project.name}</span>\n          </div>\n          <div className=\"project-row__right\">\n            <span className=\"project-row__deleted-badge\">Archived</span>\n            {project.dashboardGuid && (\n              <span\n  onClick={() => openDashboard(project)}\n  title=\"Open Dashboard\"\n  style={{ display: 'inline-flex', alignItems: 'center', justifyContent: 'center', width: 26, height: 26, borderRadius: 6, border: '1px solid rgba(255,255,255,0.12)', background: 'rgba(255,255,255,0.05)', cursor: 'pointer', flexShrink: 0 }}\n>\n  <svg width=\"13\" height=\"13\" viewBox=\"0 0 13 13\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n    <rect x=\"1\" y=\"1\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.9\"/>\n    <rect x=\"7.5\" y=\"1\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.6\"/>\n    <rect x=\"1\" y=\"7.5\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.6\"/>\n    <rect x=\"7.5\" y=\"7.5\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.35\"/>\n  </svg>\n</span>\n            )}\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  if (project.billingOnly && project.billingNotConfigured) {\n    return (\n      <div className={'project-row project-row--billing' + (expanded ? ' project-row--expanded' : '')} style={{ animationDelay: index * 80 + 'ms' }}>\n        <div className=\"project-row__main\" onClick={() => setExpanded(prev => !prev)} style={{ cursor: 'pointer' }}>\n          <div className=\"project-row__left\">\n            <span className=\"status-dot status-dot--grey\" />\n            <span className=\"project-row__name\">{project.name}</span>\n            <span style={{ fontSize: 10, fontWeight: 600, color: '#4285f4', background: 'rgba(66,133,244,0.12)', border: '1px solid rgba(66,133,244,0.25)', borderRadius: 100, padding: '2px 8px', letterSpacing: '0.5px', textTransform: 'uppercase' }}>Not Configured</span>\n          </div>\n          <div className=\"project-row__right\">\n            <span className={'project-row__chevron' + (expanded ? ' project-row__chevron--open' : '')}>›</span>\n          </div>\n        </div>\n        {expanded && (\n          <div className=\"project-row__detail\" style={{ paddingBottom: 12 }}>\n            <GcpBillingNotConfigured />\n          </div>\n        )}\n      </div>\n    );\n  }\n\n  if (project.billingOnly) {\n    const billing    = resourceStatuses.find((r) => r.type === 'aws_billing');\n    const totalCost  = billingCost ?? billing?.row?.totalCostINR ?? null;\n    const costLabel  = totalCost != null ? '₹' + totalCost.toFixed(0) : null;\n    const bStatus    = billingCostToStatus(totalCost);\n    const dotCls     = bStatus === 'unknown' ? 'grey' : bStatus;\n    const statusText = bStatus === 'green' ? 'Within Budget' : bStatus === 'yellow' ? 'Nearing Budget' : bStatus === 'red' ? 'Over Budget' : 'Informational';\n    const statusColor = bStatus === 'green' ? '#00d4aa' : bStatus === 'yellow' ? '#f5a623' : bStatus === 'red' ? '#ff4d6d' : '#7a8aaa';\n    return (\n      <div className={'project-row project-row--billing' + (expanded ? ' project-row--expanded' : '') + (bStatus !== 'unknown' ? ' project-row--' + bStatus : '')} style={{ animationDelay: index * 80 + 'ms' }}>\n        <div className=\"project-row__main\" onClick={() => setExpanded(prev => !prev)} style={{ cursor: 'pointer' }}>\n          <div className=\"project-row__left\">\n            <span className={'status-dot status-dot--' + dotCls} />\n            <span className=\"project-row__name\">{project.name}</span>\n            {costLabel && <span className=\"project-row__uptime-pill\">{costLabel} this month</span>}\n          </div>\n          <div className=\"project-row__right\">\n            <span className=\"project-row__status-text\" style={{ color: statusColor }}>{statusText}</span>\n            <span className={'project-row__chevron' + (expanded ? ' project-row__chevron--open' : '')}>›</span>\n            <span\n  onClick={(e) => { e.stopPropagation(); openDashboard(project); }}\n  title=\"Open Dashboard\"\n  style={{ display: 'inline-flex', alignItems: 'center', justifyContent: 'center', width: 26, height: 26, borderRadius: 6, border: '1px solid rgba(255,255,255,0.12)', background: 'rgba(255,255,255,0.05)', cursor: 'pointer', flexShrink: 0 }}\n>\n  <svg width=\"13\" height=\"13\" viewBox=\"0 0 13 13\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n    <rect x=\"1\" y=\"1\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.9\"/>\n    <rect x=\"7.5\" y=\"1\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.6\"/>\n    <rect x=\"1\" y=\"7.5\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.6\"/>\n    <rect x=\"7.5\" y=\"7.5\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.35\"/>\n  </svg>\n</span>\n          </div>\n        </div>\n        {expanded && (\n          <div className=\"project-row__detail\" style={{ paddingBottom: 12 }}>\n            <BillingSimple cost={totalCost} budget={BILLING_BUDGET_INR} />\n          </div>\n        )}\n      </div>\n    );\n  }\n\n  if (project.empty) {\n    return (\n      <div className=\"project-row project-row--clickable\" style={{ animationDelay: index * 80 + 'ms', cursor: 'pointer', background: 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.08)', borderRadius: 10, marginBottom: 4 }} onClick={() => openDashboard(project)}>\n        <div className=\"project-row__main\">\n          <div className=\"project-row__left\" style={{ gap: 10 }}>\n            <span style={{ fontSize: 14, color: '#7a8aaa' }}>◎</span>\n            <span className=\"project-row__name\" style={{ color: '#c8d4f0' }}>{project.name}</span>\n          </div>\n          <div className=\"project-row__right\">\n            <span style={{ fontSize: 10, fontWeight: 600, color: '#8899bb', background: 'rgba(100,120,170,0.18)', border: '1px solid rgba(100,120,170,0.4)', borderRadius: 100, padding: '2px 10px', letterSpacing: '0.5px', textTransform: 'uppercase' }}>No Monitoring</span>\n            <span\n  onClick={() => openDashboard(project)}\n  title=\"Open Dashboard\"\n  style={{ display: 'inline-flex', alignItems: 'center', justifyContent: 'center', width: 26, height: 26, borderRadius: 6, border: '1px solid rgba(255,255,255,0.12)', background: 'rgba(255,255,255,0.05)', cursor: 'pointer', flexShrink: 0 }}\n>\n  <svg width=\"13\" height=\"13\" viewBox=\"0 0 13 13\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n    <rect x=\"1\" y=\"1\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.9\"/>\n    <rect x=\"7.5\" y=\"1\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.6\"/>\n    <rect x=\"1\" y=\"7.5\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.6\"/>\n    <rect x=\"7.5\" y=\"7.5\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.35\"/>\n  </svg>\n</span>\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  const status       = loading ? 'unknown' : worstStatus(resourceStatuses.map((r) => r.status));\n  const hasResources = project.resources && project.resources.length > 0;\n  const hasDashboard = !!(project.dashboardGuid || project.dashboardLink);\n\n  const handleRowClick = useCallback(() => {\n    if (hasResources) setExpanded((prev) => !prev);\n    else if (hasDashboard) openDashboard(project);\n  }, [project, hasResources, hasDashboard]);\n\n  const handleChevronClick = useCallback((e) => {\n    e.stopPropagation();\n    openDashboard(project);\n  }, [project]);\n\n  const uptimeSummary = (() => {\n    if (loading) return null;\n    const crStatuses = resourceStatuses.filter((r) => r.type === 'gcp_cloudrun' && r.row);\n    if (crStatuses.length === 0) return null;\n    const allUp  = crStatuses.every((r) => r.status === 'green');\n    const someUp = crStatuses.some((r)  => r.status === 'green');\n    if (allUp) return '100%';\n    if (someUp) return 'Partial';\n    return 'Down';\n  })();\n\n  const billingSummary = (() => {\n    if (loading) return null;\n    const billing = resourceStatuses.find((r) => r.type === 'aws_billing' && r.row);\n    if (!billing || billing.row?.totalCostINR == null) return null;\n    return `₹${billing.row.totalCostINR.toFixed(0)}`;\n  })();\n\n  return (\n    <div\n      className={`project-row project-row--${status}${expanded ? ' project-row--expanded' : ''}${hasDashboard || hasResources ? ' project-row--clickable' : ''}`}\n      style={{ animationDelay: `${index * 80}ms` }}\n    >\n      <div className=\"project-row__main\" onClick={handleRowClick}>\n        <div className=\"project-row__left\">\n          <StatusDot status={status} />\n          <span className=\"project-row__name\">{project.name}</span>\n          {!loading && uptimeSummary !== null && <span className=\"project-row__uptime-pill\">{uptimeSummary} uptime</span>}\n          {!loading && billingSummary !== null && <span className=\"project-row__uptime-pill\">{billingSummary} today</span>}\n        </div>\n        <div className=\"project-row__right\">\n          <span className={`project-row__status-text project-row__status-text--${status === 'unknown' ? 'grey' : status}`}>\n            {STATUS_META[status]?.label ?? 'Healthy'}\n          </span>\n          {hasResources && !loading && (\n            <span className={`project-row__chevron${expanded ? ' project-row__chevron--open' : ''}`} onClick={(e) => { e.stopPropagation(); setExpanded(p => !p); }}>\n              ›\n            </span>\n          )}\n          {hasDashboard && <span\n  onClick={(e) => { e.stopPropagation(); openDashboard(project); }}\n  title=\"Open Dashboard\"\n  style={{ display: 'inline-flex', alignItems: 'center', justifyContent: 'center', width: 26, height: 26, borderRadius: 6, border: '1px solid rgba(255,255,255,0.12)', background: 'rgba(255,255,255,0.05)', cursor: 'pointer', flexShrink: 0 }}\n>\n  <svg width=\"13\" height=\"13\" viewBox=\"0 0 13 13\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n    <rect x=\"1\" y=\"1\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.9\"/>\n    <rect x=\"7.5\" y=\"1\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.6\"/>\n    <rect x=\"1\" y=\"7.5\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.6\"/>\n    <rect x=\"7.5\" y=\"7.5\" width=\"4.5\" height=\"4.5\" rx=\"1\" fill=\"#7a8aaa\" opacity=\"0.35\"/>\n  </svg>\n</span>}\n        </div>\n      </div>\n      {expanded && hasResources && (\n        <div className=\"project-row__detail\">\n          {loading ? (\n            <span className=\"project-row__detail-loading\">Checking resource health…</span>\n          ) : (\n            <div className=\"project-row__resource-list\" style={{ display: 'flex', flexDirection: 'column', gap: '2px', padding: '8px 0' }}>\n              {resourceStatuses.map((r, i) => (\n                <ExpandableResourceRow key={i} resource={r} project={project} />\n              ))}\n            </div>\n          )}\n        </div>\n      )}\n    </div>\n  );\n};\n\n// ─── NAVIGATION HELPER ───────────────────────────────────────────────────────\nconst openDashboard = (project) => {\n  if (project.dashboardGuid) {\n    try {\n      navigation.openStackedNerdlet({\n        id: 'dashboards.detail',\n        urlState: {\n          entityGuid: project.dashboardGuid,\n          timeRange: project.billingOnly\n            ? { begin_time: Date.now() - 30 * 24 * 60 * 60 * 1000, end_time: Date.now() }\n            : { duration: 86400000 },\n        },\n      });\n      return;\n    } catch (_) {}\n  }\n  if (project.dashboardLink) window.open(project.dashboardLink, '_blank');\n};\n\n// ─── CLOUD CARD SHELL ─────────────────────────────────────────────────────────\nconst CloudCard = ({ provider }) => {\n  const meta = PROVIDER_META[provider.id];\n  return (\n    <div className={`cloud-card cloud-card--${provider.id}`} style={{ background: meta.gradient }}>\n      <ProjectListInner provider={provider} projectIndex={0} results={[]} />\n    </div>\n  );\n};\n\n// ─── SINGLE RESOURCE QUERY ───────────────────────────────────────────────────\nconst extractRow = (data) => {\n  if (!Array.isArray(data) || data.length === 0) return null;\n  const row = {};\n  const SKIP_KEYS = new Set(['x', 'y', 'begin_time', 'end_time', 'beginTimeSeconds', 'endTimeSeconds', 'timestamp', 'inspect']);\n  data.forEach((series) => {\n    if (!series?.data?.length) return;\n    const point = series.data[0];\n    const key   = series?.metadata?.name || series?.presentation?.name || series?.metadata?.contents?.[0]?.alias || null;\n    if (key) {\n      if (point?.y !== undefined && point.y !== null) { row[key] = point.y; return; }\n      if (point?.[key] !== undefined && point[key] !== null) { row[key] = point[key]; return; }\n    }\n    if (point && typeof point === 'object') {\n      Object.entries(point).forEach(([k, v]) => {\n        if (!SKIP_KEYS.has(k) && typeof v === 'number' && !(k in row)) row[k] = v;\n      });\n    }\n  });\n  return Object.keys(row).length > 0 ? row : null;\n};\n\nconst SingleResourceQuery = ({ resource, gcpProjectId, children }) => {\n  const query = buildResourceQuery(resource, gcpProjectId);\n  // Timeout: if NrqlQuery stays in loading state for >6s, treat as no data.\n  // This prevents indefinitely-loading rows when an integration isn't configured.\n  const [timedOut, setTimedOut] = React.useState(false);\n  React.useEffect(() => {\n    const t = setTimeout(() => setTimedOut(true), 6000);\n    return () => clearTimeout(t);\n  }, [query]);\n\n  return (\n    <NrqlQuery accountIds={[ACCOUNT_ID]} query={query} pollInterval={60000}>\n      {({ data, loading, error }) => {\n        let resourceStatus;\n        if (loading && !timedOut) {\n          resourceStatus = { ...resource, status: 'unknown', row: null, loading: true };\n        } else if (loading && timedOut) {\n          resourceStatus = { ...resource, status: noData(resource), row: null, loading: false };\n        } else if (error || !data) {\n          resourceStatus = { ...resource, status: noData(resource), row: null, loading: false };\n        } else {\n          const row    = extractRow(data);\n          const status = row === null ? noData(resource) : deriveResourceStatus(resource, row);\n          resourceStatus = { ...resource, status, row, loading: false };\n        }\n        return children(resourceStatus);\n      }}\n    </NrqlQuery>\n  );\n};\n\nconst ProjectResourceLoader = ({ project, resourceIndex, collectedStatuses, projectIndex, provider, results }) => {\n  if (resourceIndex >= project.resources.length) {\n    const anyLoading = collectedStatuses.some((r) => r.loading);\n    return (\n      <ProjectListInner\n        provider={provider}\n        projectIndex={projectIndex + 1}\n        results={[...results, { projectIndex, loading: anyLoading, resourceStatuses: collectedStatuses }]}\n      />\n    );\n  }\n  const resource = project.resources[resourceIndex];\n  return (\n    <SingleResourceQuery resource={resource} gcpProjectId={project.gcpProjectId}>\n      {(resourceStatus) => (\n        <ProjectResourceLoader\n          project={project}\n          resourceIndex={resourceIndex + 1}\n          collectedStatuses={[...collectedStatuses, resourceStatus]}\n          projectIndex={projectIndex}\n          provider={provider}\n          results={results}\n        />\n      )}\n    </SingleResourceQuery>\n  );\n};\n\nconst ProjectListInner = ({ provider, projectIndex, results }) => {\n  if (projectIndex >= provider.projects.length) {\n    if (provider.id === 'aws') {\n      const billingQ = `SELECT max(\\`aws.billing.EstimatedCharges\\`) * 92 AS totalCostINR FROM Metric WHERE aws.Namespace = 'AWS/Billing' SINCE 1 day ago`;\n      return (\n        <NrqlQuery accountIds={[ACCOUNT_ID]} query={billingQ} pollInterval={300000}>\n          {({ data }) => {\n            const billingCost = data?.[0]?.data?.[0]?.y ?? data?.[0]?.data?.[0]?.totalCostINR ?? null;\n            return <ProjectsRendered provider={provider} allResults={results} billingCost={billingCost} />;\n          }}\n        </NrqlQuery>\n      );\n    }\n    return <ProjectsRendered provider={provider} allResults={results} billingCost={null} />;\n  }\n\n  const project = provider.projects[projectIndex];\n  if (project.deleted || project.empty || project.billingNotConfigured || !project.resources || project.resources.length === 0) {\n    return (\n      <ProjectListInner\n        provider={provider}\n        projectIndex={projectIndex + 1}\n        results={[...results, { projectIndex, loading: false, resourceStatuses: [] }]}\n      />\n    );\n  }\n  return (\n    <ProjectResourceLoader\n      project={project}\n      resourceIndex={0}\n      collectedStatuses={[]}\n      projectIndex={projectIndex}\n      provider={provider}\n      results={results}\n    />\n  );\n};\n\n// ─── PROJECTS RENDERED ────────────────────────────────────────────────────────\nconst ProjectsRendered = ({ provider, allResults, billingCost }) => {\n  const projectStatuses = provider.projects.map((p, i) => {\n    if (p.deleted) return 'deleted';\n    if (p.empty)   return 'empty';\n    if (p.billingNotConfigured) return 'unknown';\n    const r = allResults.find((res) => res.projectIndex === i) ?? allResults[i];\n    if (!r || r.loading) return 'unknown';\n    if (!r.resourceStatuses || r.resourceStatuses.length === 0) return 'unknown';\n    return worstStatus(r.resourceStatuses.map((rs) => rs.status));\n  });\n\n  const liveStatuses  = projectStatuses.filter((s) => s !== 'deleted' && s !== 'empty' && s !== 'unknown');\n  const cloudStatus   = liveStatuses.length > 0 ? worstStatus(liveStatuses) : 'green';\n  const billingStatus = billingCostToStatus(billingCost);\n  const overallStatus = provider.id === 'aws'\n    ? worstStatus([cloudStatus, billingStatus].filter(s => s !== 'unknown'))\n    : cloudStatus;\n  const cardMeta = STATUS_META[overallStatus] ?? STATUS_META.green;\n  const meta     = PROVIDER_META[provider.id];\n\n  return (\n    <>\n      <style>{`\n        .cloud-card--${provider.id} {\n          border-color: ${cardMeta.color} !important;\n          box-shadow: 0 8px 40px ${cardMeta.color}22, inset 0 1px 0 rgba(255,255,255,0.07) !important;\n        }\n      `}</style>\n      <div className=\"cloud-card__header\">\n        <div className=\"cloud-card__title-group\">\n          <div className=\"cloud-card__icon\" style={{ color: meta.accent }}>{provider.icon}</div>\n          <div>\n            <h2 className=\"cloud-card__name\">{provider.name}</h2>\n            <span className=\"cloud-card__label\">{provider.label}</span>\n          </div>\n          <div className=\"cloud-card__header-pills\">\n            <StatusBadge status={cloudStatus} label=\"Resources\" />\n            {provider.id === 'aws' && <BillingHealthBadge cost={billingCost} />}\n          </div>\n        </div>\n      </div>\n      <div className=\"cloud-card__divider\" />\n      <div className=\"cloud-card__projects\">\n        {provider.projects.map((project, i) => {\n          const r = allResults.find((res) => res.projectIndex === i) ?? allResults[i];\n          return (\n            <ProjectRow\n              key={project.name}\n              project={project}\n              resourceStatuses={r?.resourceStatuses ?? []}\n              loading={r?.loading ?? false}\n              index={i}\n              billingCost={project.billingOnly ? billingCost : null}\n            />\n          );\n        })}\n      </div>\n    </>\n  );\n};\n\n// ─── MAIN COMPONENT ──────────────────────────────────────────────────────────\nexport default class EagleEye extends React.Component {\n  render() {\n    return (\n      <div className=\"eagle-eye\">\n        <div className=\"bg-orb bg-orb--blue\" />\n        <div className=\"bg-orb bg-orb--orange\" />\n        <div className=\"bg-orb bg-orb--green\" />\n\n        <header className=\"ee-header\">\n          <div className=\"ee-header__eyebrow\">Infrastructure Monitoring</div>\n          <h1 className=\"ee-header__title\">\n            <span className=\"ee-header__title-eagle\">Eagle</span>\n            <span className=\"ee-header__title-eye\"> Eye</span>\n          </h1>\n          <div className=\"ee-header__pulse-bar\">\n            <span className=\"ee-header__pulse-dot\" />\n            <span className=\"ee-header__pulse-label\">Live · auto-refreshes every 60s</span>\n          </div>\n        </header>\n\n        <div className=\"ee-grid\">\n          {CLOUD_PROVIDERS.map((provider) => (\n            <CloudCard key={provider.id} provider={provider} />\n          ))}\n        </div>\n\n        <footer className=\"ee-footer\">\n          <span>Click any project to expand health details · click the grid icon to open its dashboard</span>\n        </footer>\n      </div>\n    );\n  }\n}\n"]}}