ilter}\n              SINCE 30 minutes ago`;\n\n    // ── GCP Billing ──────────────────────────────────────────────────────────\n    case 'gcp_billing':\n      return `SELECT count(*) AS samples FROM Metric SINCE 1 hour ago LIMIT 1`;\n\n    // ── AWS App Runner ───────────────────────────────────────────────────────\n    case 'aws_apprunner':\n      return `SELECT\n                max(\\`aws.apprunner.ActiveInstances\\`) AS peakInstances,\n                sum(\\`aws.apprunner.Requests\\`) AS totalRequests,\n                average(\\`aws.apprunner.RequestLatency\\`) AS avgLatency,\n                sum(\\`aws.apprunner.4xxStatusResponses\\`) AS errors4xx,\n                count(*) AS samples\n              FROM Metric\n              WHERE aws.Namespace = 'AWS/AppRunner'\n              SINCE 30 minutes ago`;\n\n    // ── AWS RDS ──────────────────────────────────────────────────────────────\n    case 'aws_rds':\n      return `SELECT\n                average(\\`aws.rds.FreeableMemory\\`) AS freeMemory,\n                average(\\`aws.rds.WriteIOPS\\`) AS writeIOPS,\n                average(\\`aws.rds.WriteLatency\\`) AS writeLatency,\n                count(*) AS samples\n              FROM Metric\n              WHERE aws.Namespace = 'AWS/RDS'\n              SINCE 1 hour ago`;\n\n    // ── AWS CloudFront ───────────────────────────────────────────────────────\n    case 'aws_cloudfront':\n      return `SELECT\n                average(\\`aws.cloudfront.5xxErrorRate\\`) AS errorRate5xx,\n                average(\\`aws.cloudfront.TotalErrorRate\\`) AS totalErrorRate,\n                sum(\\`aws.cloudfront.Requests\\`) AS totalRequests\n              FROM Metric\n              WHERE aws.Namespace = 'AWS/CloudFront'\n              SINCE 24 hours ago`;\n\n    // ── AWS EC2 ──────────────────────────────────────────────────────────────\n    case 'aws_ec2':\n      return `SELECT\n                average(provider.cpuUtilization) AS cpuUsage,\n                max(provider.statusCheckFailed) AS statusCheckFailed,\n                max(provider.statusCheckFailedInstance) AS instanceCheckFailed,\n                count(*) AS samples\n              FROM ComputeSample\n              WHERE provider = 'Ec2Instance'\n              SINCE 30 minutes ago`;\n\n    // ── AWS Billing ──────────────────────────────────────────────────────────\n    case 'aws_billing':\n      return `SELECT\n                max(\\`aws.billing.EstimatedCharges\\`) * 92 AS totalCostINR,\n                count(*) AS samples\n              FROM Metric\n              WHERE aws.Namespace = 'AWS/Billing'\n              SINCE 1 hour ago`;\n\n    default:\n      return `SELECT count(*) AS samples\n              FROM Metric\n              WHERE entity.name = '${resource.label}'\n              SINCE 5 minutes ago`;\n  }\n};\n\n\n// ─── HEALTH DERIVATION ───────────────────────────────────────────────────────\nconst noData = (resource) => {\n  if (resource.scalesToZero) return 'green';\n  return resource.alwaysOn ? 'yellow' : 'unknown';\n};\n\nconst deriveResourceStatus = (resource, row) => {\n  if (!row) return noData(resource);\n\n  switch (resource.type) {\n\n    // ── GCP Cloud Run ──────────────────────────────────────────────────────\n    case 'gcp_cloudrun': {\n      const samples = row.samples ?? 0;\n      if (samples === 0) return noData(resource);\n      return 'green';\n    }\n\n    // ── GCP Cloud SQL ──────────────────────────────────────────────────────\n    case 'gcp_cloudsql': {\n      const samples = row.samples ?? 0;\n      if (samples === 0) return noData(resource);\n      return 'green';\n    }\n\n    // ── GCP BigQuery ───────────────────────────────────────────────────────\n    case 'gcp_bigquery': {\n      const samples = row.samples ?? 0;\n      if (samples === 0) return 'unknown';\n      return 'green';\n    }\n\n    // ── GCP Billing ────────────────────────────────────────────────────────\n    case 'gcp_billing': {\n      return 'unknown';\n    }\n\n    // ── AWS App Runner ─────────────────────────────────────────────────────\n    case 'aws_apprunner': {\n      const samples = row.samples ?? 0;\n      if (samples === 0) return noData(resource);\n      const peak = row.peakInstances ?? null;\n      if (peak === null || peak === 0) return 'yellow'; // Paused\n      return 'green'; // Running\n    }\n\n    // ── AWS RDS ────────────────────────────────────────────────────────────\n    case 'aws_rds': {\n      const samples  = row.samples    ?? 0;\n      if (samples === 0) return noData(resource);\n      const freeMem  = row.freeMemory   ?? null;\n      const writeLat = row.writeLatency ?? null;\n      if (freeMem !== null && freeMem < 50 * 1024 * 1024)  return 'red';\n      if (freeMem !== null && freeMem < 200 * 1024 * 1024) return 'yellow';\n      if (writeLat !== null && writeLat > 1)                return 'yellow';\n      return 'green';\n    }\n\n    // ── AWS CloudFront ─────────────────────────────────────────────────────\n    case 'aws_cloudfront': {\n      const requests = row.totalRequests ?? null;\n      const err5xx   = row.errorRate5xx  ?? null;\n      const errAll   = row.totalErrorRate ?? null;\n      if (requests === null && err5xx === null && errAll === null) return noData(resource);\n      const rate = err5xx ?? errAll ?? null;\n      if (rate !== null && rate > 5) return 'red';\n      if (rate !== null && rate > 2) return 'yellow';\n      return 'green';\n    }\n\n    // ── AWS EC2 ────────────────────────────────────────────────────────────\n    case 'aws_ec2': {\n      const samples      = row.samples ?? 0;\n      if (samples === 0) return noData(resource);\n      const statusFailed = typeof row.statusCheckFailed   === 'number' ? row.statusCheckFailed   : 0;\n      const instanceFail = typeof row.instanceCheckFailed === 'number' ? row.instanceCheckFailed : 0;\n      const cpu          = typeof row.cpuUsage            === 'number' ? row.cpuUsage            : null;\n      if (statusFailed > 0 || instanceFail > 0) return 'red';\n      if (cpu !== null && cpu > 90) return 'red';\n      if (cpu !== null && cpu > 75) return 'yellow';\n      return 'green';\n    }\n\n    // ── AWS Billing ────────────────────────────────────────────────────────\n    case 'aws_billing': {\n      const samples = row.samples ?? 0;\n      if (samples === 0) return 'unknown';\n      return 'green';\n    }\n\n    default: {\n      const samples = row.samples ?? 0;\n      return samples === 0 ? noData(resource) : 'green';\n    }\n  }\n};\n\n// ─── STATUS UTILS ────────────────────────────────────────────────────────────\nconst worstStatus = (statuses) => {\n  if (statuses.some((s) => s === 'red'))    return 'red';\n  if (statuses.some((s) => s === 'yellow')) return 'yellow';\n  if (statuses.some((s) => s === 'green'))  return 'green';\n  return 'unknown';\n};\n\nconst projectStatus = (resourceStatuses) => {\n  const statuses = resourceStatuses.map((r) => r.status);\n  return worstStatus(statuses);\n};\n\nconst STATUS_META = {\n  green:   { label: 'Healthy',      color: '#00d4aa' },\n  yellow:  { label: 'Warning',      color: '#f5a623' },\n  red:     { label: 'Critical',     color: '#ff4d6d' },\n  unknown: { label: 'Loading...',   color: '#7a8aaa' },\n  deleted: { label: 'Deleted',      color: '#4a5568' },\n  empty:   { label: 'No Resources', color: '#3d4a66' },\n};\n\nconst PROVIDER_META = {\n  gcp: {\n    gradient: 'linear-gradient(135deg, rgba(66,133,244,0.18) 0%, rgba(52,168,83,0.10) 100%)',\n    accent: '#4285F4',\n  },\n  aws: {\n    gradient: 'linear-gradient(135deg, rgba(255,153,0,0.18) 0%, rgba(255,90,0,0.10) 100%)',\n    accent: '#FF9900',\n  },\n};\n\n// ─── RESOURCE TYPE HELPERS ───────────────────────────────────────────────────\n// Only App Runner supports the \"Paused\" state; all other resources use \"Stopped\"\nconst canBePaused = (resourceType) => resourceType === 'aws_apprunner';\n\n// ─── BILLING HEALTH BADGE ────────────────────────────────────────────────────\nconst BILLING_BUDGET_INR = 4600;\n\nconst billingCostToStatus = (cost) => {\n  if (cost === null) return 'unknown';\n  const pct = (cost / BILLING_BUDGET_INR) * 100;\n  return pct >= 70 ? 'red' : pct >= 50 ? 'yellow' : 'green';\n};\n\nconst BillingHealthBadge = ({ cost }) => {\n  if (cost === null) {\n    return (\n      <span className=\"status-badge status-badge--grey\">\n        <span className=\"status-badge__dot\" />\n        Billing\n      </span>\n    );\n  }\n  const pct    = (cost / BILLING_BUDGET_INR) * 100;\n  const status = billingCostToStatus(cost);\n  return (\n    <span className={'status-badge status-badge--' + status + ' status-badge--billing'} title={pct.toFixed(1) + '% of monthly budget'}>\n      <span className=\"status-badge__dot\" />\n      <span className=\"status-badge__billing-current\">{'₹' + cost.toFixed(0)}</span>\n      <span className=\"status-badge__billing-sep\">/</span>\n      <span className=\"status-badge__billing-budget\">{'₹' + BILLING_BUDGET_INR + ' budget'}</span>\n    </span>\n  );\n};\n\n// ─── STATUS DOT ──────────────────────────────────────────────────────────────\nconst StatusDot = ({ status }) => {\n  const cls = (status === 'unknown' || status === 'deleted' || status === 'empty') ? 'grey' : status;\n  return <span className={`status-dot status-dot--${cls}`} />;\n};\n\n// ─── STATUS BADGE ─────────────────────────────────────────────────────────────\nconst StatusBadge = ({ status, label }) => {\n  const meta = STATUS_META[status] ?? STATUS_META.green;\n  const cls  = (status === 'unknown' || status === 'deleted' || status === 'empty') ? 'grey' : status;\n  return (\n    <span className={`status-badge status-badge--${cls}`}>\n      <span className=\"status-badge__dot\" />\n      {label ? label : meta.label}\n    </span>\n  );\n};\n\n// ─── RESOURCE METRICS DISPLAY ────────────────────────────────────────────────\nconst ResourceMetrics = ({ resource, row }) => {\n  if (!row) return null;\n\n  switch (resource.type) {\n    case 'gcp_cloudrun': {\n      const billable = row.billableTime != null ? `${row.billableTime.toFixed(1)}s` : '0.0s';\n      const active   = row.billableTime != null && row.billableTime > 0;\n      const status   = active ? '✓ Running' : '✓ Scaled to zero';\n      const color    = '#00d4aa';\n      return (\n        <span className=\"resource-metrics\">\n          <strong style={{ color }}>{status}</strong> · Billable: <strong>{billable}</strong>\n        </span>\n      );\n    }\n    case 'gcp_cloudsql': {\n      const samples = row.samples ?? 0;\n      const label   = samples > 0 ? '✓ Running' : '✗ Stopped';\n      const color   = samples > 0 ? '#00d4aa' : '#f5a623';\n      return (\n        <span className=\"resource-metrics\">\n          DB: <strong style={{ color }}>{label}</strong>\n        </span>\n      );\n    }\n    case 'aws_apprunner': {\n      const instances = row.peakInstances != null ? row.peakInstances.toFixed(0) : '0';\n      const requests  = row.totalRequests != null ? row.totalRequests.toFixed(0) : '0';\n      const latency   = row.avgLatency    != null ? `${row.avgLatency.toFixed(0)} ms` : 'N/A';\n      const errors4xx = row.errors4xx     != null ? row.errors4xx.toFixed(0)     : '0';\n      return (\n        <span className=\"resource-metrics\">\n          Peak instances: <strong>{instances}</strong> · Requests: <strong>{requests}</strong> · Latency: <strong>{latency}</strong> · 4xx: <strong>{errors4xx}</strong>\n        </span>\n      );\n    }\n    case 'aws_rds': {\n      const freeMem  = row.freeMemory   != null\n        ? `${(row.freeMemory / (1024 * 1024)).toFixed(0)} MB free`\n        : 'N/A';\n      const writeLat = row.writeLatency != null\n        ? `${(row.writeLatency * 1000).toFixed(1)} ms`\n        : 'N/A';\n      return (\n        <span className=\"resource-metrics\">\n          Mem: <strong>{freeMem}</strong> · Write latency: <strong>{writeLat}</strong>\n        </span>\n      );\n    }\n    case 'aws_ec2': {\n      const cpu    = row.cpuUsage           != null ? `${row.cpuUsage.toFixed(1)}%` : 'N/A';\n      const status = row.statusCheckFailed  != null\n        ? (row.statusCheckFailed > 0 ? '✗ Failed' : '✓ OK')\n        : 'N/A';\n      const color  = row.statusCheckFailed > 0 ? '#ff4d6d' : '#00d4aa';\n      return (\n        <span className=\"resource-metrics\">\n          CPU: <strong>{cpu}</strong> · Status check: <strong style={{ color }}>{status}</strong>\n        </span>\n      );\n    }\n    case 'aws_cloudfront': {\n      const err5xx = row.errorRate5xx   != null ? `${row.errorRate5xx.toFixed(2)}%`   : 'N/A';\n      const errAll = row.totalErrorRate != null ? `${row.totalErrorRate.toFixed(2)}%` : 'N/A';\n      const reqs   = row.totalRequests  != null ? ` · Requests: ${row.totalRequests.toFixed(0)}` : '';\n      return (\n        <span className=\"resource-metrics\">\n          5xx: <strong>{err5xx}</strong> · Total err: <strong>{errAll}</strong>{reqs}\n        </span>\n      );\n    }\n    case 'aws_billing': {\n      const cost = row.totalCostINR != null ? `₹${row.totalCostINR.toFixed(2)}` : 'N/A';\n      return (\n        <span className=\"resource-metrics\">\n          Est. Cost (today): <strong>{cost}</strong>\n        </span>\n      );\n    }\n    default:\n      return null;\n  }\n};\n\n// ─── CLOUD RUN INSTANCE LIST ─────────────────────────────────────────────────\nconst CloudRunInstanceList = ({ gcpProjectId }) => {\n  if (!gcpProjectId) return null;\n\n  const query = `SELECT sum(container.BillableInstanceTime) AS billableTime\n                 FROM GcpRunRevisionSample\n                 WHERE projectId = '${gcpProjectId}'\n                 FACET serviceName\n                 SINCE 30 minutes ago\n                 LIMIT 50`;\n\n  return (\n    <NrqlQuery accountIds={[ACCOUNT_ID]} query={query} pollInterval={60000}>\n      {({ data, loading, error }) => {\n        if (loading) return (\n          <div className=\"cr-instances cr-instances--loading\">\n            <span style={{ fontSize: '11px', color: '#7a8aaa', fontStyle: 'italic' }}>Loading instances…</span>\n          </div>\n        );\n        if (error || !data || data.length === 0) return null;\n\n        const instances = data\n          .map((series) => {\n            let serviceName = series?.metadata?.name ?? null;\n\n            if (!serviceName || serviceName === 'Other') {\n              const groups = series?.metadata?.groups ?? [];\n              const g = groups.find(g => g.type === 'facet' || g.name === 'serviceName');\n              serviceName = g?.value ?? null;\n            }\n\n            if (!serviceName) {\n              const facets = series?.metadata?.facets ?? [];\n              serviceName = facets[0] ?? null;\n            }\n\n            if (!serviceName) return null;\n\n            const billable = series?.data?.[0]?.y ?? 0;\n            return { serviceName, billable, active: billable > 0 };\n          })\n          .filter(Boolean);\n\n        if (instances.length === 0) return null;\n\n        instances.sort((a, b) => {\n          if (a.active !== b.active) return b.active ? 1 : -1;\n          return a.serviceName.localeCompare(b.serviceName);\n        });\n\n        return (\n          <div className=\"cr-instances\">\n            <div className=\"cr-instances__header\">\n              ☁ Cloud Run Services ({instances.length})\n            </div>\n            {instances.map((inst, i) => {\n              const statusLabel = inst.active ? '▶ Running' : '◼ Scaled to zero';\n              const statusColor = '#00d4aa';\n              return (\n                <div key={i} className=\"cr-instances__row\">\n                  <span className=\"status-dot status-dot--green\" style={{ width: 7, height: 7 }} />\n                  <span className=\"cr-instances__name\">{inst.serviceName}</span>\n                  <span className=\"cr-instances__status\" style={{ color: statusColor }}>\n                    {statusLabel}\n                  </span>\n                  {inst.active && (\n                    <span className=\"cr-instances__billable\">\n                      {inst.billable.toFixed(1)}s billable\n                    </span>\n                  )}\n                </div>\n              );\n            })}\n          </div>\n        );\n      }}\n    </NrqlQuery>\n  );\n};\n\n// ─── AWS SERVICE NAME LIST (generic reusable toggle) ─────────────────────────\nconst AwsServiceToggle = ({ label, query, nameField, statusField, statusFn }) => {\n  const [open, setOpen] = React.useState(false);\n  const accentColor = '#FF9900';\n  return (\n    <div style={{ marginTop: 6 }}>\n      <div\n        onClick={() => setOpen(o => !o)}\n        style={{ cursor: 'pointer', display: 'flex', alignItems: 'center', gap: 6,\n                 fontSize: 11, fontWeight: 700, color: accentColor, letterSpacing: 1,\n                 textTransform: 'uppercase', padding: '4px 2px', userSelect: 'none' }}\n      >\n        <span style={{ display: 'inline-block', transition: 'transform 0.2s',\n                       transform: open ? 'rotate(90deg)' : 'rotate(0deg)' }}>›</span>\n        {label}\n      </div>\n      {open && (\n        <NrqlQuery accountIds={[ACCOUNT_ID]} query={query} pollInterval={60000}>\n          {({ data, loading }) => {\n            if (loading) return <div style={{ fontSize: 11, color: '#7a8aaa', padding: '4px 8px', fontStyle: 'italic' }}>Loading…</div>;\n            if (!data || data.length === 0) return <div style={{ fontSize: 11, color: '#7a8aaa', padding: '4px 8px' }}>No instances found</div>;\n            const seen = new Set();\n            const items = data.map(series => {\n              const name = series?.metadata?.name ?? null;\n              if (!name || seen.has(name)) return null;\n              seen.add(name);\n              const val = series?.data?.[0]?.y ?? null;\n              const status = statusFn ? statusFn(val) : 'green';\n              const color  = status === 'red' ? '#ff4d6d' : status === 'yellow' ? '#f5a623' : '#00d4aa';\n              return { name, val, status, color };\n            }).filter(Boolean);\n            if (items.length === 0) return null;\n            return (\n              <div style={{ background: 'rgba(255,153,0,0.06)', border: '1px solid rgba(255,153,0,0.15)', borderRadius: 8, overflow: 'hidden', marginTop: 4 }}>\n                <div style={{ fontSize: 10, fontWeight: 700, color: accentColor, padding: '6px 12px 4px', borderBottom: '1px solid rgba(255,153,0,0.1)', letterSpacing: 1, textTransform: 'uppercase' }}>\n                  {label} ({items.length})\n                </div>\n                {items.map((inst, i) => (\n                  <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 8, padding: '5px 12px', borderBottom: i < items.length - 1 ? '1px solid rgba(255,255,255,0.04)' : 'none' }}>\n                    <span className={'status-dot status-dot--' + inst.status} style={{ width: 7, height: 7 }} />\n                    <span style={{ flex: 1, fontSize: 11, fontWeight: 500, color: '#f0f4ff', fontFamily: 'monospace', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{inst.name}</span>\n                    <span style={{ fontSize: 11, fontWeight: 600, color: inst.color }}>✓ Running</span>\n                  </div>\n                ))}\n              </div>\n            );\n          }}\n        </NrqlQuery>\n      )}\n    </div>\n  );\n};\n\n// ─── EXPANDABLE RESOURCE ROW ─────────────────────────────────────────────────\nconst SERVICE_QUERIES = {\n  gcp_cloudrun:   (p) => `SELECT count(*) AS val FROM GcpRunRevisionSample WHERE projectId = '${p.gcpProjectId}' FACET serviceName SINCE 30 minutes ago LIMIT 50`,\n  gcp_cloudsql:   (p) => `SELECT count(*) AS val FROM GcpCloudSqlSample WHERE projectId = '${p.gcpProjectId}' FACET displayName SINCE 30 minutes ago LIMIT 20`,\n  gcp_bigquery:   (p) => `SELECT count(*) AS val FROM GcpBigQueryDataSetSample WHERE projectId = '${p.gcpProjectId}' FACET datasetId SINCE 30 minutes ago LIMIT 20`,\n  aws_apprunner:  ()  => \"SELECT count(*) AS val FROM Metric WHERE aws.Namespace = 'AWS/AppRunner' FACET aws.apprunner.ServiceName SINCE 30 minutes ago LIMIT 30\",\n  aws_rds:        ()  => \"SELECT latest(provider.dbInstanceIdentifier) AS val FROM DatastoreSample WHERE provider = 'RdsDbInstance' FACET provider.dbInstanceIdentifier SINCE 7 days ago LIMIT 20\",\n  aws_ec2:        ()  => \"SELECT latest(entityName) AS val FROM ComputeSample WHERE provider = 'Ec2Instance' FACET entityName SINCE 7 days ago LIMIT 20\",\n  aws_cloudfront: ()  => \"SELECT count(*) AS val FROM Metric WHERE aws.Namespace = 'AWS/CloudFront' FACET aws.cloudfront.DistributionId SINCE 24 hours ago LIMIT 20\",\n};\n\nconst extractFacetName = (series) => {\n  // 1. Best source: the facet group value set by NR1\n  const groups = series?.metadata?.groups;\n  if (Array.isArray(groups)) {\n    const g = groups.find(g => g.type === 'facet');\n    if (g?.value && g.value !== 'Other') return g.value;\n  }\n  // 2. Facet array on the data point itself (raw NRQL response)\n  const pt = series?.data?.[0];\n  if (pt?.facet) return Array.isArray(pt.facet) ? pt.facet[0] : String(pt.facet);\n  // 3. metadata.name — only use if it looks like an instance/service name, not a metric alias\n  const name = series?.metadata?.name;\n  const METRIC_ALIASES = new Set(['val', 'Other', 'unknown', 'count', 'latest',\n    'FreeableMemory', 'WriteIOPS', 'WriteLatency', 'ReadIOPS', 'CPUUtilization']);\n  if (name && !METRIC_ALIASES.has(name)) return name;\n  return null;\n};\n\nconst ExpandableResourceRow = ({ resource: r, project }) => {\n  const [open, setOpen] = React.useState(false);\n  const hasSubList = !!SERVICE_QUERIES[r.type];\n\n  const dotCls      = r.status === 'green' ? 'green' : r.status === 'yellow' ? 'yellow' : r.status === 'red' ? 'red' : 'grey';\n  const statusColor = r.status === 'green' ? '#00d4aa' : r.status === 'yellow' ? '#f5a623' : r.status === 'red' ? '#ff4d6d' : '#7a8aaa';\n\n  // Only App Runner can be \"Paused\"; RDS, EC2 and all others use \"Stopped\"\n  const statusLabel = r.status === 'green'  ? '✓ Running'\n                    : r.status === 'yellow' ? (canBePaused(r.type) ? '⊘ Paused' : '✗ Stopped')\n                    : r.status === 'red'    ? '✗ Stopped'\n                    : '— No Data';\n\n  const query = hasSubList ? SERVICE_QUERIES[r.type](project) : null;\n\n  return (\n    <div style={{ borderRadius: 6, overflow: 'hidden', background: 'rgba(255,255,255,0.03)' }}>\n      <div\n        style={{ display: 'flex', alignItems: 'center', gap: 8, padding: '5px 8px', cursor: hasSubList ? 'pointer' : 'default' }}\n        onClick={() => hasSubList && setOpen(o => !o)}\n      >\n        <span className={'status-dot status-dot--' + dotCls} />\n        <span style={{ fontWeight: 600, fontSize: '0.8rem', minWidth: 80, color: '#f0f4ff', flex: 1 }}>{r.label}</span>\n        <span style={{ color: statusColor, fontSize: '0.75rem', fontWeight: 600 }}>{statusLabel}</span>\n        {hasSubList && (\n          <span style={{ fontSize: 14, color: '#3d4a66', transition: 'transform 0.2s', display: 'inline-block', transform: open ? 'rotate(90deg)' : 'rotate(0deg)' }}>›</span>\n        )}\n      </div>\n      {open && query && (\n        <NrqlQuery accountIds={[ACCOUNT_ID]} query={query} pollInterval={60000}>\n          {({ data, loading }) => {\n            if (loading) return <div style={{ padding: '4px 12px 6px', fontSize: 11, color: '#7a8aaa', fontStyle: 'italic' }}>Loading…</div>;\n            if (!data || data.length === 0) return <div style={{ padding: '4px 12px 6px', fontSize: 11, color: '#7a8aaa' }}>No instances found</div>;\n            const seen = new Set();\n            const items = data.map(series => {\n              const name = extractFacetName(series);\n              if (!name || seen.has(name)) return null;\n              seen.add(name);\n              return name;\n            }).filter(Boolean);\n            if (items.length === 0) return <div style={{ padding: '4px 12px 6px', fontSize: 11, color: '#7a8aaa' }}>No instances found</div>;\n            const accentColor = r.type.startsWith('aws') ? 'rgba(255,153,0,0.08)' : 'rgba(66,133,244,0.08)';\n            const borderColor = r.type.startsWith('aws') ? 'rgba(255,153,0,0.12)' : 'rgba(66,133,244,0.12)';\n            // For App Runner: individual services can be paused; for RDS/EC2: always \"Stopped\" when not running\n            const instDot   = r.status === 'green' ? 'green' : 'yellow';\n            const instLabel = r.status === 'green'\n              ? '✓ Running'\n              : canBePaused(r.type) ? '⊘ Paused' : '✗ Stopped';\n            const instColor = r.status === 'green' ? '#00d4aa' : '#f5a623';\n            return (\n              <div style={{ margin: '0 8px 6px', background: accentColor, border: '1px solid ' + borderColor, borderRadius: 6, overflow: 'hidden' }}>\n                {items.map((name, i) => (\n                  <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 8, padding: '4px 10px', borderBottom: i < items.length - 1 ? '1px solid rgba(255,255,255,0.04)' : 'none' }}>\n                    <span className={'status-dot status-dot--' + instDot} style={{ width: 6, height: 6, flexShrink: 0 }} />\n                    <span style={{ fontSize: 11, color: '#c8d4f0', fontFamily: 'monospace', flex: 1, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{name}</span>\n                    <span style={{ fontSize: 10, color: instColor, fontWeight: 600 }}>{instLabel}</span>\n                  </div>\n                ))}\n              </div>\n            );\n          }}\n        </NrqlQuery>\n      )}\n    </div>\n  );\n};\n\n// ─── CLOUD RUN TOGGLE ────────────────────────────────────────────────────────\nconst CloudRunToggle = ({ gcpProjectId }) => {\n  const [open, setOpen] = React.useState(false);\n  return (\n    <div style={{ marginTop: 6 }}>\n      <div\n        onClick={() => setOpen(o => !o)}\n        style={{ cursor: 'pointer', display: 'flex', alignItems: 'center', gap: 6,\n                 fontSize: 11, fontWeight: 700, color: '#4285f4', letterSpacing: 1,\n                 textTransform: 'uppercase', padding: '4px 2px', userSelect: 'none' }}\n      >\n        <span style={{ display: 'inline-block', transition: 'transform 0.2s',\n                       transform: open ? 'rotate(90deg)' : 'rotate(0deg)' }}>›</span>\n        Cloud Run Services\n      </div>\n      {open && <CloudRunInstanceList gcpProjectId={gcpProjectId} />}\n    </div>\n  );\n};\n\n// ─── BILLING SIMPLE ───────────────────────────────────────────────────────────\nconst BillingSimple = ({ cost, budget }) => {\n  if (cost === null) return (\n    <div style={{ color: '#7a8aaa', fontSize: 12, fontStyle: 'italic' }}>No billing data</div>\n  );\n  const now         = new Date();\n  const dayOfMonth  = now.getDate();\n  const daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();\n  const estimated   = (cost / dayOfMonth) * daysInMonth;\n\n  const status   = billingCostToStatus(cost);\n  const estStatus= billingCostToStatus(estimated);\n  const color    = status    === 'red' ? '#ff4d6d' : status    === 'yellow' ? '#f5a623' : '#00d4aa';\n  const estColor = estStatus === 'red' ? '#ff4d6d' : estStatus === 'yellow' ? '#f5a623' : '#00d4aa';\n  const pct      = Math.min((cost / budget) * 100, 100);\n  const fullPct  = ((cost / budget) * 100).toFixed(1);\n\n  const statStyle  = { flex: 1, padding: '8px 10px', background: 'rgba(255,255,255,0.03)', borderRadius: 8, border: '1px solid rgba(255,255,255,0.07)' };\n  const labelStyle = { fontSize: 10, color: '#7a8aaa', textTransform: 'uppercase', letterSpacing: 1, marginBottom: 4 };\n  const valStyle   = (c) => ({ fontSize: 18, fontWeight: 800, color: c });\n\n  return (\n    <div style={{ padding: '6px 4px' }}>\n      <div style={{ display: 'flex', gap: 8, marginBottom: 10 }}>\n        <div style={statStyle}>\n          <div style={labelStyle}>Current</div>\n          <div style={valStyle(color)}>{'₹' + cost.toFixed(0)}</div>\n        </div>\n        <div style={statStyle}>\n          <div style={labelStyle}>Est. Month-end</div>\n          <div style={valStyle(estColor)}>{'₹' + estimated.toFixed(0)}</div>\n        </div>\n        <div style={statStyle}>\n          <div style={labelStyle}>Budget</div>\n          <div style={valStyle('#f0f4ff')}>{'₹' + budget}</div>\n        </div>\n      </div>\n      <div style={{ background: 'rgba(255,255,255,0.06)', borderRadius: 4, height: 6, overflow: 'hidden' }}>\n        <div style={{ height: '100%', width: pct + '%', background: color, borderRadius: 4, transition: 'width 0.4s' }} />\n      </div>\n      <div style={{ marginTop: 4, fontSize: 10, color: color, textAlign: 'right', fontWeight: 600 }}>\n        {fullPct + '% of budget used · Day ' + dayOfMonth + ' of ' + daysInMonth}\n      </div>\n    </div>\n  );\n};\n\n// ─── GCP BILLING NOT CONFIGURED PANEL ────────────────────────────────────────\nconst GcpBillingNotConfigured = () => (\n  <div style={{\n    display: 'flex', alignItems: 'flex-start', gap: 10,\n    padding: '10px 12px',\n    background: 'rgba(66,133,244,0.06)',\n    border: '1px dashed rgba(66,133,244,0.25)',\n    borderRadius: 8,\n    margin: '4px 0',\n  }}>\n    <span style={{ fontSize: 16, lineHeight: 1.2, opacity: 0.6 }}>🔧</span>\n    <div>\n      <div style={{ fontSize: 12, fontWeight: 700, color: '#4285f4', marginBottom: 2 }}>\n        Not Configured\n      </div>\n      <div style={{ fontSize: 11, color: '#7a8aaa', lineHeight: 1.5 }}>\n        GCP Billing export to BigQuery has not been set up yet.\n        Configure it in the GCP Console to enable cost monitoring here.\n      </div>\n    </div>\n  </div>\n);\n\n// ─── DOWN SERVICES PANEL ──────────────────────────────────────────────────────\nconst DownServicesPanel = ({ downResources }) => {\n  if (!downResources || downResources.length === 0) return null;\n  return (\n    <div className=\"down-services\">\n      <div className=\"down-services__header\">\n        <span className=\"down-services__icon\">⚠</span>\n        <span className=\"down-services__title\">Services Requiring Attention</span>\n      </div>\n      <ul className=\"down-services__list\">\n        {downResources.map((r, i) => {\n          const badgeCls   = r.status === 'unknown' ? 'grey' : r.status;\n          const isStopped  = !r.row || (r.row.samples ?? 0) === 0;\n          // Paused label only for App Runner; everything else is Stopped\n          const badgeLabel = r.status === 'unknown' ? 'No Data'\n                           : r.status === 'red'     ? (isStopped ? 'Stopped' : 'Critical')\n                           : r.status === 'yellow'  ? (canBePaused(r.type) ? 'Paused' : 'Stopped')\n                           : 'OK';\n          return (\n            <li key={i} className={`down-services__item down-services__item--${badgeCls}`}>\n              <span className=\"down-services__item-dot\" />\n              <span className=\"down-services__item-name\">{r.label}</span>\n              <span className={`down-services__item-badge down-services__item-badge--${badgeCls}`}>\n                {badgeLabel}\n              </span>\n            </li>\n          );\n        })}\n      </ul>\n    </div>\n  );\n};\n\n// ─── BILLING BREAKDOWN ───────────────────────────────────────────────────────\nconst BillingBreakdown = () => {\n  const totalQuery = `SELECT max(\\`aws.billing.EstimatedCharges\\`) * 92 AS totalINR\n                      FROM Metric WHERE aws.Namespace = 'AWS/Billing'\n                      AND aws.ServiceName IS NULL\n                      SINCE 1 day ago`;\n\n  const byServiceQuery = `SELECT max(\\`aws.billing.EstimatedCharges\\`) * 92 AS costINR\n                           FROM Metric WHERE aws.Namespace = 'AWS/Billing'\n                           AND aws.ServiceName IS NOT NULL\n                           FACET aws.ServiceName\n                           SINCE 1 day ago\n                           LIMIT 20`;\n\n  return (\n    <NrqlQuery accountIds={[ACCOUNT_ID]} query={byServiceQuery} pollInterval={300000}>\n      {({ data: svcData, loading: svcLoading }) => (\n        <NrqlQuery accountIds={[ACCOUNT_ID]} query={totalQuery} pollInterval={300000}>\n          {({ data: totData, loading: totLoading }) => {\n            if (svcLoading || totLoading) {\n              return <div style={{ color: '#7a8aaa', fontSize: 12, padding: '8px 0', fontStyle: 'italic' }}>Loading billing data…</div>;\n            }\n\n            const totalINR = totData?.[0]?.data?.[0]?.y ?? totData?.[0]?.data?.[0]?.totalINR ?? null;\n\n            const services = (svcData || [])\n              .map(series => {\n                const name = series?.metadata?.name || '—';\n                const cost = series?.data?.[0]?.y ?? series?.data?.[0]?.costINR ?? 0;\n                return { name, cost };\n              })\n              .filter(s => s.name !== '—' && s.cost > 0)\n              .sort((a, b) => b.cost - a.cost);\n\n            return (\n              <div className=\"billing-breakdown\">\n                {totalINR != null && (\n                  <div className=\"billing-breakdown__total\">\n                    <span className=\"billing-breakdown__total-label\">Total this month</span>\n                    <span className=\"billing-breakdown__total-value\">₹{totalINR.toFixed(2)}</span>\n                  </div>\n                )}\n                {services.length > 0 ? (\n                  <div className=\"billing-breakdown__services\">\n                    {services.map((s, i) => {\n                      const pct = totalINR ? (s.cost / totalINR) * 100 : 0;\n                      return (\n                        <div key={i} className=\"billing-breakdown__row\">\n                          <span className=\"billing-breakdown__svc-name\">{s.name}</span>\n                          <div className=\"billing-breakdown__bar-wrap\">\n                            <div className=\"billing-breakdown__bar\" style={{ width: `${Math.min(pct, 100)}%` }} />\n                          </div>\n                          <span className=\"billing-breakdown__svc-cost\">₹{s.cost.toFixed(0)}</span>\n                          <span className=\"billing-breakdown__svc-pct\">{pct.toFixed(1)}%</span>\n                        </div>\n                      );\n                    })}\n                  </div>\n                ) : (\n                  <div style={{ color: '#7a8aaa', fontSize: 12, padding: '4px 0' }}>No per-service data available</div>\n                )}\n              </div>\n            );\n          }}\n        </NrqlQuery>\n      )}\n    </NrqlQuery>\n  );\n};\n\n// ─── PROJECT ROW ─────────────────────────────────────────────────────────────\nconst ProjectRow = ({ project, resourceStatuses, loading, index, billingCost }) => {\n  const [expanded, setExpanded] = useState(false);\n\n  if (project.deleted) {\n    return (\n      <div className=\"project-row project-row--deleted\" style={{ animationDelay: index * 80 + 'ms' }}>\n        <div className=\"project-row__main\">\n          <div className=\"project-row__left\" style={{ gap: 10 }}>\n            <span style={{ fontSize: 14, opacity: 0.4 }}>🗑</span>\n            <span className=\"project-row__name\">{project.name}</span>\n          </div>\n          <div className=\"project-row__right\">\n            <span className=\"project-row__deleted-badge\">Archived</span>\n            {project.dashboardGuid && (\n              <span\n                className=\"project-row__chevron\"\n                onClick={() => openDashboard(project)}\n                title=\"Open archived dashboard\"\n                style={{ fontSize: 14, opacity: 0.4 }}\n              >↗</span>\n            )}\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  // ── GCP Billing (not configured) ───────────────────────────────────────────\n  if (project.billingOnly && project.billingNotConfigured) {\n    return (\n      <div\n        className={'project-row project-row--billing' + (expanded ? ' project-row--expanded' : '')}\n        style={{ animationDelay: index * 80 + 'ms' }}\n      >\n        <div\n          className=\"project-row__main\"\n          onClick={() => setExpanded(prev => !prev)}\n          style={{ cursor: 'pointer' }}\n        >\n          <div className=\"project-row__left\">\n            <span className=\"status-dot status-dot--grey\" />\n            <span className=\"project-row__name\">{project.name}</span>\n            <span style={{\n              fontSize: 10, fontWeight: 600, color: '#4285f4',\n              background: 'rgba(66,133,244,0.12)', border: '1px solid rgba(66,133,244,0.25)',\n              borderRadius: 100, padding: '2px 8px', letterSpacing: '0.5px', textTransform: 'uppercase',\n            }}>Not Configured</span>\n          </div>\n          <div className=\"project-row__right\">\n            <span className={'project-row__chevron' + (expanded ? ' project-row__chevron--open' : '')}>›</span>\n          </div>\n        </div>\n\n        {expanded && (\n          <div className=\"project-row__detail\" style={{ paddingBottom: 12 }}>\n            <GcpBillingNotConfigured />\n          </div>\n        )}\n      </div>\n    );\n  }\n\n  if (project.billingOnly) {\n    const billing   = resourceStatuses.find((r) => r.type === 'aws_billing');\n    const totalCost = billingCost ?? billing?.row?.totalCostINR ?? null;\n    const costLabel = totalCost != null ? '₹' + totalCost.toFixed(0) : null;\n    const bStatus   = billingCostToStatus(totalCost);\n    const dotCls    = bStatus === 'unknown' ? 'grey' : bStatus;\n    const statusText = bStatus === 'green'  ? 'Within Budget'\n                     : bStatus === 'yellow' ? 'Nearing Budget'\n                     : bStatus === 'red'    ? 'Over Budget'\n                     : 'Informational';\n    const statusColor = bStatus === 'green'  ? '#00d4aa'\n                      : bStatus === 'yellow' ? '#f5a623'\n                      : bStatus === 'red'    ? '#ff4d6d'\n                      : '#7a8aaa';\n\n    return (\n      <div\n        className={'project-row project-row--billing' + (expanded ? ' project-row--expanded' : '') + (bStatus !== 'unknown' ? ' project-row--' + bStatus : '')}\n        style={{ animationDelay: index * 80 + 'ms' }}\n      >\n        <div className=\"project-row__main\" onClick={() => setExpanded(prev => !prev)} style={{ cursor: 'pointer' }}>\n          <div className=\"project-row__left\">\n            <span className={'status-dot status-dot--' + dotCls} />\n            <span className=\"project-row__name\">{project.name}</span>\n            {costLabel && <span className=\"project-row__uptime-pill\">{costLabel} this month</span>}\n          </div>\n          <div className=\"project-row__right\">\n            <span className=\"project-row__status-text\" style={{ color: statusColor }}>{statusText}</span>\n            <span className={'project-row__chevron' + (expanded ? ' project-row__chevron--open' : '')}>›</span>\n            <span\n              className=\"project-row__chevron\"\n              onClick={(e) => { e.stopPropagation(); openDashboard(project); }}\n              title=\"Open AWS Billing Dashboard\"\n            >↗</span>\n          </div>\n        </div>\n\n        {expanded && (\n          <div className=\"project-row__detail\" style={{ paddingBottom: 12 }}>\n            <BillingSimple cost={totalCost} budget={BILLING_BUDGET_INR} />\n          </div>\n        )}\n      </div>\n    );\n  }\n\n  if (project.empty) {\n    return (\n      <div\n        className=\"project-row project-row--empty project-row--clickable\"\n        style={{ animationDelay: index * 80 + 'ms', cursor: 'pointer' }}\n        onClick={() => openDashboard(project)}\n        title={'Open ' + project.name + ' dashboard'}\n      >\n        <div className=\"project-row__main\">\n          <div className=\"project-row__left\" style={{ gap: 10 }}>\n            <span style={{ fontSize: 14, opacity: 0.5 }}>◎</span>\n            <span className=\"project-row__name\">{project.name}</span>\n            <span style={{ fontSize: 10, fontWeight: 600, color: '#3d4a66', background: 'rgba(61,74,102,0.2)', border: '1px solid rgba(61,74,102,0.3)', borderRadius: 100, padding: '2px 8px', letterSpacing: '0.5px', textTransform: 'uppercase' }}>No Monitoring</span>\n          </div>\n          <div className=\"project-row__right\">\n            <span className=\"project-row__chevron\" style={{ opacity: 0.5 }}>↗</span>\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  const status = loading ? 'green' : worstStatus(resourceStatuses.map((r) => r.status));\n  const downResources = resourceStatuses.filter(\n    (r) => r.status === 'red' || r.status === 'yellow'\n  );\n  const hasResources = project.resources && project.resources.length > 0;\n  const hasDashboard = !!(project.dashboardGuid || project.dashboardLink);\n\n  const handleRowClick = useCallback(() => {\n    if (hasResources) {\n      setExpanded((prev) => !prev);\n    } else if (hasDashboard) {\n      openDashboard(project);\n    }\n  }, [project, hasResources, hasDashboard]);\n\n  const handleChevronClick = useCallback((e) => {\n    e.stopPropagation();\n    openDashboard(project);\n  }, [project]);\n\n  const uptimeSummary = (() => {\n    if (loading) return null;\n    const crStatuses = resourceStatuses.filter((r) => r.type === 'gcp_cloudrun' && r.row);\n    if (crStatuses.length === 0) return null;\n    const allUp  = crStatuses.every((r) => r.status === 'green');\n    const someUp = crStatuses.some((r) => r.status === 'green');\n    if (allUp)  return '100%';\n    if (someUp) return 'Partial';\n    return 'Down';\n  })();\n\n  const billingSummary = (() => {\n    if (loading) return null;\n    const billing = resourceStatuses.find((r) => r.type === 'aws_billing' && r.row);\n    if (!billing || billing.row?.totalCostINR == null) return null;\n    return `₹${billing.row.totalCostINR.toFixed(0)}`;\n  })();\n\n  return (\n    <div\n      className={`project-row project-row--${status}${expanded ? ' project-row--expanded' : ''}${hasDashboard || hasResources ? ' project-row--clickable' : ''}`}\n      style={{ animationDelay: `${index * 80}ms` }}\n    >\n      <div className=\"project-row__main\" onClick={handleRowClick}>\n        <div className=\"project-row__left\">\n          <StatusDot status={status} />\n          <span className=\"project-row__name\">{project.name}</span>\n\n          {!loading && uptimeSummary !== null && (\n            <span className=\"project-row__uptime-pill\">{uptimeSummary} uptime</span>\n          )}\n          {!loading && billingSummary !== null && (\n            <span className=\"project-row__uptime-pill\">{billingSummary} today</span>\n          )}\n        </div>\n        <div className=\"project-row__right\">\n          <span className={`project-row__status-text project-row__status-text--${status === 'unknown' ? 'grey' : status}`}>\n            {STATUS_META[status]?.label ?? 'Healthy'}\n          </span>\n          {hasResources && (\n            <span\n              className={`project-row__chevron${expanded ? ' project-row__chevron--open' : ''}`}\n              onClick={handleChevronClick}\n              title={hasDashboard ? `Open ${project.name} dashboard` : undefined}\n            >\n              {hasDashboard ? '↗' : '›'}\n            </span>\n          )}\n          {!hasResources && hasDashboard && (\n            <span className=\"project-row__chevron\">↗</span>\n          )}\n        </div>\n      </div>\n\n      {expanded && hasResources && (\n        <div className=\"project-row__detail\">\n          {loading ? (\n            <span className=\"project-row__detail-loading\">Checking resource health…</span>\n          ) : (\n            <>\n              <div className=\"project-row__resource-list\" style={{ display: 'flex', flexDirection: 'column', gap: '2px', padding: '8px 0' }}>\n                {resourceStatuses.map((r, i) => (\n                  <ExpandableResourceRow\n                    key={i}\n                    resource={r}\n                    project={project}\n                  />\n                ))}\n              </div>\n            </>\n          )}\n        </div>\n      )}\n    </div>\n  );\n};\n\n// ─── NAVIGATION HELPER ───────────────────────────────────────────────────────\nconst openDashboard = (project) => {\n  if (project.dashboardGuid) {\n    try {\n      navigation.openStackedNerdlet({\n        id: 'dashboards.detail',\n        urlState: {\n          entityGuid: project.dashboardGuid,\n          timeRange: project.billingOnly\n            ? { begin_time: Date.now() - 30 * 24 * 60 * 60 * 1000, end_time: Date.now() }\n            : { duration: 86400000 },\n        },\n      });\n      return;\n    } catch (_) {}\n  }\n  if (project.dashboardLink) {\n    window.open(project.dashboardLink, '_blank');\n  }\n};\n\n// ─── CLOUD CARD SHELL ─────────────────────────────────────────────────────────\nconst CloudCard = ({ provider }) => {\n  const meta = PROVIDER_META[provider.id];\n  return (\n    <div\n      className={`cloud-card cloud-card--${provider.id}`}\n      style={{ background: meta.gradient }}\n    >\n      <ProjectListInner provider={provider} projectIndex={0} results={[]} />\n    </div>\n  );\n};\n\n// ─── SINGLE RESOURCE QUERY ───────────────────────────────────────────────────\nconst extractRow = (data) => {\n  if (!Array.isArray(data) || data.length === 0) return null;\n  const row = {};\n  const SKIP_KEYS = new Set(['x', 'y', 'begin_time', 'end_time', 'beginTimeSeconds', 'endTimeSeconds', 'timestamp', 'inspect']);\n\n  data.forEach((series) => {\n    if (!series?.data?.length) return;\n    const point = series.data[0];\n\n    const key = series?.metadata?.name\n             || series?.presentation?.name\n             || series?.metadata?.contents?.[0]?.alias\n             || null;\n\n    if (key) {\n      if (point?.y !== undefined && point.y !== null) {\n        row[key] = point.y;\n        return;\n      }\n      if (point?.[key] !== undefined && point[key] !== null) {\n        row[key] = point[key];\n        return;\n      }\n    }\n\n    if (point && typeof point === 'object') {\n      Object.entries(point).forEach(([k, v]) => {\n        if (!SKIP_KEYS.has(k) && typeof v === 'number' && !(k in row)) {\n          row[k] = v;\n        }\n      });\n    }\n  });\n\n  return Object.keys(row).length > 0 ? row : null;\n};\n\nconst SingleResourceQuery = ({ resource, gcpProjectId, children }) => {\n  const query = buildResourceQuery(resource, gcpProjectId);\n  return (\n    <NrqlQuery accountIds={[ACCOUNT_ID]} query={query} pollInterval={60000}>\n      {({ data, loading, error }) => {\n        let resourceStatus;\n        if (loading) {\n          resourceStatus = { ...resource, status: 'green', row: null, loading: true };\n        } else if (error || !data) {\n          resourceStatus = { ...resource, status: noData(resource), row: null, loading: false };\n        } else {\n          const row    = extractRow(data);\n          const status = row === null ? noData(resource) : deriveResourceStatus(resource, row);\n          resourceStatus = { ...resource, status, row, loading: false };\n        }\n        return children(resourceStatus);\n      }}\n    </NrqlQuery>\n  );\n};\n\nconst ProjectResourceLoader = ({ project, resourceIndex, collectedStatuses, projectIndex, provider, results }) => {\n  if (resourceIndex >= project.resources.length) {\n    const anyLoading = collectedStatuses.some((r) => r.loading);\n    return (\n      <ProjectListInner\n        provider={provider}\n        projectIndex={projectIndex + 1}\n        results={[...results, { projectIndex, loading: anyLoading, resourceStatuses: collectedStatuses }]}\n      />\n    );\n  }\n\n  const resource = project.resources[resourceIndex];\n\n  return (\n    <SingleResourceQuery\n      resource={resource}\n      gcpProjectId={project.gcpProjectId}\n    >\n      {(resourceStatus) => (\n        <ProjectResourceLoader\n          project={project}\n          resourceIndex={resourceIndex + 1}\n          collectedStatuses={[...collectedStatuses, resourceStatus]}\n          projectIndex={projectIndex}\n          provider={provider}\n          results={results}\n        />\n      )}\n    </SingleResourceQuery>\n  );\n};\n\nconst ProjectListInner = ({ provider, projectIndex, results }) => {\n  if (projectIndex >= provider.projects.length) {\n    if (provider.id === 'aws') {\n      const billingQ = `SELECT max(\\`aws.billing.EstimatedCharges\\`) * 92 AS totalCostINR FROM Metric WHERE aws.Namespace = 'AWS/Billing' SINCE 1 day ago`;\n      return (\n        <NrqlQuery accountIds={[ACCOUNT_ID]} query={billingQ} pollInterval={300000}>\n          {({ data }) => {\n            const billingCost = data?.[0]?.data?.[0]?.y ?? data?.[0]?.data?.[0]?.totalCostINR ?? null;\n            return <ProjectsRendered provider={provider} allResults={results} billingCost={billingCost} />;\n          }}\n        </NrqlQuery>\n      );\n    }\n    return <ProjectsRendered provider={provider} allResults={results} billingCost={null} />;\n  }\n\n  const project = provider.projects[projectIndex];\n\n  // Skip resource loading for deleted, empty, and not-configured billing projects\n  if (project.deleted || project.empty || project.billingNotConfigured || !project.resources || project.resources.length === 0) {\n    return (\n      <ProjectListInner\n        provider={provider}\n        projectIndex={projectIndex + 1}\n        results={[...results, { projectIndex, loading: false, resourceStatuses: [] }]}\n      />\n    );\n  }\n\n  return (\n    <ProjectResourceLoader\n      project={project}\n      resourceIndex={0}\n      collectedStatuses={[]}\n      projectIndex={projectIndex}\n      provider={provider}\n      results={results}\n    />\n  );\n};\n\n// ─── PROJECTS RENDERED ────────────────────────────────────────────────────────\nconst ProjectsRendered = ({ provider, allResults, billingCost }) => {\n  const projectStatuses = provider.projects.map((p, i) => {\n    if (p.deleted) return 'deleted';\n    if (p.empty)   return 'empty';\n    if (p.billingNotConfigured) return 'unknown';\n    const r = allResults.find((res) => res.projectIndex === i) ?? allResults[i];\n    if (!r) return 'unknown';\n    if (r.loading) return 'unknown';\n    if (!r.resourceStatuses || r.resourceStatuses.length === 0) return 'unknown';\n    const statuses = r.resourceStatuses.map((rs) => rs.status);\n    return worstStatus(statuses);\n  });\n\n  const liveStatuses    = projectStatuses.filter((s) => s !== 'deleted' && s !== 'empty' && s !== 'unknown');\n  const definedStatuses = liveStatuses.filter((s) => s !== 'unknown');\n  const cloudStatus     = definedStatuses.length > 0 ? worstStatus(definedStatuses) : 'green';\n\n  const billingStatus = billingCostToStatus(billingCost);\n  const overallStatus = provider.id === 'aws'\n    ? worstStatus([cloudStatus, billingStatus].filter(s => s !== 'unknown'))\n    : cloudStatus;\n  const cardMeta = STATUS_META[overallStatus] ?? STATUS_META.green;\n\n  const meta = PROVIDER_META[provider.id];\n\n  return (\n    <>\n      <style>{`\n        .cloud-card--${provider.id} {\n          border-color: ${cardMeta.color} !important;\n          box-shadow: 0 8px 40px ${cardMeta.color}22,\n                      inset 0 1px 0 rgba(255,255,255,0.07) !important;\n        }\n      `}</style>\n\n      <div className=\"cloud-card__header\">\n        <div className=\"cloud-card__title-group\">\n          <div className=\"cloud-card__icon\" style={{ color: meta.accent }}>\n            {provider.icon}\n          </div>\n          <div>\n            <h2 className=\"cloud-card__name\">{provider.name}</h2>\n            <span className=\"cloud-card__label\">{provider.label}</span>\n          </div>\n          <div className=\"cloud-card__header-pills\">\n            <StatusBadge status={cloudStatus} label=\"Resources\" />\n            {provider.id === 'aws' && <BillingHealthBadge cost={billingCost} />}\n          </div>\n        </div>\n      </div>\n      <div className=\"cloud-card__divider\" />\n\n      <div className=\"cloud-card__projects\">\n        {provider.projects.map((project, i) => {\n          const r = allResults.find((res) => res.projectIndex === i) ?? allResults[i];\n          return (\n            <ProjectRow\n              key={project.name}\n              project={project}\n              resourceStatuses={r?.resourceStatuses ?? []}\n              loading={r?.loading ?? false}\n              index={i}\n              billingCost={project.billingOnly ? billingCost : null}\n            />\n          );\n        })}\n      </div>\n    </>\n  );\n};\n\n// ─── MAIN COMPONENT ──────────────────────────────────────────────────────────\nexport default class EagleEye extends React.Component {\n  render() {\n    return (\n      <div className=\"eagle-eye\">\n        <div className=\"bg-orb bg-orb--blue\" />\n        <div className=\"bg-orb bg-orb--orange\" />\n        <div className=\"bg-orb bg-orb--green\" />\n\n        <header className=\"ee-header\">\n          <div className=\"ee-header__eyebrow\">Infrastructure Monitoring</div>\n          <h1 className=\"ee-header__title\">\n            <span className=\"ee-header__title-eagle\">Eagle</span>\n            <span className=\"ee-header__title-eye\"> Eye</span>\n          </h1>\n          <div className=\"ee-header__pulse-bar\">\n            <span className=\"ee-header__pulse-dot\" />\n            <span className=\"ee-header__pulse-label\">Live · auto-refreshes every 60s</span>\n          </div>\n        </header>\n\n        <div className=\"ee-grid\">\n          {CLOUD_PROVIDERS.map((provider) => (\n            <CloudCard key={provider.id} provider={provider} />\n          ))}\n        </div>\n\n        <footer className=\"ee-footer\">\n          <span>Click any project to expand health details · click ↗ to open its dashboard</span>\n        </footer>\n      </div>\n    );\n  }\n}\n"]}}